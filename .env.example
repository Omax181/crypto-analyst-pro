# === IA (Gemini) ===
GEMINI_API_KEY=            # https://aistudio.google.com/apikey
GEMINI_MODEL=              # pin manuel OPTIONNEL du modèle rapide (vide = défauts $0 du code)
GEMINI_MODEL_DEEP=         # escape PAYANT (ex. gemini-2.5-pro) pour l'analyse profonde ; vide = flash gratuit
GEMINI_FALLBACK_MODEL=     # modèle de repli OPTIONNEL (vide = défaut du code)
GEMINI_BOT_MODEL=          # modèle du bot Telegram (vide = défaut du code)
GEMINI_BOT_FALLBACK=       # repli du bot (vide = défaut du code)
GEMINI_LAST_CHANCE_PAUSE_S=  # pause (s) de l'ultime tentative weekly (défaut 600, 0 = off)

# === Sources crypto ===
COINGECKO_API_KEY=         # https://www.coingecko.com/en/api/pricing (free tier, optionnel)
COINMARKETCAP_API_KEY=     # https://coinmarketcap.com/api/ (free tier)
COINMARKETCAL_API_KEY=     # https://coinmarketcal.com/en/developer (catalyseurs crypto datés)
ETHERSCAN_API_KEY=         # https://etherscan.io/apis (free)
COINMETRICS_API_KEY=       # clé GRATUITE coinmetrics.io — sans elle, repli miroir CSV (MVRV daté)
COINGLASS_API_KEY=         # https://coinglass.com (free tier · dérivés)
COINGLASS_PAID=            # 1 = plan payant Coinglass (endpoints étendus), vide sinon
GLASSNODE_API_KEY=         # https://glassnode.com (free tier · on-chain)
LUNARCRUSH_API_KEY=        # https://lunarcrush.com (social trending)
LUNARCRUSH_PAID=           # 1 = plan payant LunarCrush, vide sinon
DEFILLAMA_PAID=            # 1 = plan payant DefiLlama (unlocks), vide sinon

# === Sources macro/news ===
FRED_API_KEY=              # https://fred.stlouisfed.org/docs/api/api_key.html
NEWSAPI_KEY=               # https://newsapi.org (news crypto + macro)
YOUTUBE_API_KEY=           # https://console.cloud.google.com/apis/credentials
GH_TOKEN=                  # GitHub Personal Access Token (scope: public_repo)

# === Email ===
GMAIL_USER=                # ton email gmail
GMAIL_APP_PASSWORD=        # https://myaccount.google.com/apppasswords
RECIPIENT_EMAIL=           # destinataire (peut être le même)

# === Telegram · notifications + bot conversationnel ===
TELEGRAM_BOT_TOKEN=        # @BotFather → token du bot
TELEGRAM_CHAT_ID=          # ton chat_id (seul chat servi — filtre de sécurité)
# Lecture des canaux (Watcher Guru + BRICS) · générer la session avec generate_telegram_session.py
TELEGRAM_API_ID=           # https://my.telegram.org/auth
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
# Relais Cloudflare (réveil du bot par message — cf. relay/README.md)
RELAY_PULL_URL=            # URL /pull du Worker (vide = polling getUpdates)
RELAY_SECRET=              # secret partagé avec le Worker
# Édition du portefeuille par le bot (/buy /sell /set) — OBLIGATOIRE pour écrire.
# v29 : plus AUCUN défaut en dur ; absent = aperçus seulement, aucune écriture.
PORTFOLIO_EDIT_PASSWORD=

# === Comportement (optionnel) ===
LOG_LEVEL=INFO
LEARNING_ENABLED=          # 0 = coupe le calibrateur de confiance (OB24) ; vide/1 = actif

# Polymarket et Farside ETF : aucune clé requise (API/scraping publics)
