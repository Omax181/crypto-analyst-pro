# === IA ===
GEMINI_API_KEY=            # https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.5-flash   # free tier fiable (1500 RPD). Passer à gemini-2.5-pro si tier payant.

# === Sources crypto ===
COINGECKO_API_KEY=         # https://www.coingecko.com/en/api/pricing (free tier, optionnel)
COINMARKETCAP_API_KEY=     # https://coinmarketcap.com/api/ (free tier)
CRYPTOPANIC_API_KEY=       # https://cryptopanic.com/developers/api/
ETHERSCAN_API_KEY=         # https://etherscan.io/apis (free)

# === Sources macro/news ===
FRED_API_KEY=              # https://fred.stlouisfed.org/docs/api/api_key.html
YOUTUBE_API_KEY=           # https://console.cloud.google.com/apis/credentials
GH_TOKEN=                  # GitHub Personal Access Token (scope: public_repo)

# === Email ===
GMAIL_USER=                # ton email gmail
GMAIL_APP_PASSWORD=        # https://myaccount.google.com/apppasswords
RECIPIENT_EMAIL=           # destinataire (peut être le même)

# === Optionnel ===
LOG_LEVEL=INFO
TIMEZONE=Africa/Casablanca

# === REFACTOR V2 · sources additionnelles (optionnelles) ===
COINGLASS_API_KEY=         # https://coinglass.com (free tier · dérivés)
GLASSNODE_API_KEY=         # https://glassnode.com (free tier · on-chain)
CRYPTOQUANT_API_KEY=       # https://cryptoquant.com (free tier · optionnel)
# Telegram (Watcher Guru + BRICS) · générer la session avec generate_telegram_session.py
TELEGRAM_API_ID=           # https://my.telegram.org/auth
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
# Polymarket et Farside ETF : aucune clé requise (API/scraping publics)
