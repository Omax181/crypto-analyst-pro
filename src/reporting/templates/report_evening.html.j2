  {# v15 (audit B-3) — ligne 3 : INTERNATIONAL (le crypto ne vit pas qu'aux USA). #}
  {% if _em.nikkei or _em.stoxx50 or _em.eur_usd or _em.usd_jpy %}
  <p style="font-size:9px;color:#8a8880;margin:12px 0 4px 0;text-transform:uppercase;letter-spacing:0.5px;border-top:0.5px solid #f0efe8;padding-top:10px;">International · Europe &amp; Asie</p>
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;table-layout:fixed;">
    <tr>
      {% if _em.stoxx50 %}
      <td style="width:25%;vertical-align:top;padding-right:6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Stoxx 50</p>
        <p style="font-size:15px;font-weight:500;margin:2px 0 0 0;">{{ '{:,.0f}'.format(_em.stoxx50|num(0)) }}{{ arrow24(_em.stoxx50, _em.stoxx50_delta) }}</p>
      </td>
      {% endif %}
      {% if _em.nikkei %}
      <td style="width:25%;vertical-align:top;padding-right:6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Nikkei 225</p>
        <p style="font-size:15px;font-weight:500;margin:2px 0 0 0;">{{ '{:,.0f}'.format(_em.nikkei|num(0)) }}{{ arrow24(_em.nikkei, _em.nikkei_delta) }}</p>
      </td>
      {% endif %}
      {% if _em.eur_usd %}
      <td style="width:25%;vertical-align:top;padding-right:6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">EUR/USD</p>
        <p style="font-size:15px;font-weight:500;margin:2px 0 0 0;">{{ '%.4f'|format(_em.eur_usd|num(0)) }}</p>
      </td>
      {% endif %}
      {% if _em.usd_jpy %}
      <td style="width:25%;vertical-align:top;">
        <p style="font-size:10px;color:#8a8880;margin:0;">USD/JPY</p>
        <p style="font-size:15px;font-weight:500;margin:2px 0 0 0;">{{ '%.2f'|format(_em.usd_jpy|num(0)) }}</p>
      </td>
      {% endif %}
    </tr>
  </table>
  {% endif %}
  {# v26 (E-B10) — deltas matin→soir DÉTERMINISTES (Python) : l'essence du
     « complément du matin », toujours présents même si l'IA tombe. #}
  {% if since_morning_facts and since_morning_facts.line %}
  <p style="font-size:10px;color:#5a5852;margin:10px 0 0 0;border-top:0.5px solid #f0efe8;padding-top:8px;"><span style="font-weight:600;color:#1a1a18;">Depuis le matin :</span> {{ since_morning_facts.line }}</p>
  {% endif %}
  {# v26 (E-B9/E-A14) — dérivés & flux ETF datés, 1 ligne discrète. #}
  {% if derivatives_flows_line %}
  <p style="font-size:10px;color:#5a5852;margin:{% if since_morning_facts and since_morning_facts.line %}6px{% else %}10px{% endif %} 0 0 0;{% if not (since_morning_facts and since_morning_facts.line) %}border-top:0.5px solid #f0efe8;padding-top:8px;{% endif %}"><span style="font-weight:600;color:#1a1a18;">Dérivés &amp; flux :</span> {{ derivatives_flows_line }}</p>
  {% endif %}
  {% if polymarket_facts and (polymarket_facts.fed_bars or polymarket_facts.extra_markets) %}
  {% if polymarket_facts.fed_bars %}
  {% set _pf = polymarket_facts.fed_bars %}
  <p style="font-size:10px;color:#5a5852;margin:10px 0 0 0;border-top:0.5px solid #f0efe8;padding-top:8px;">Polymarket · taux Fed{% if _pf.meeting_hint %} ({{_pf.meeting_hint}}){% endif %} : <strong>{{_pf.dominant}} {{ '%.1f'|format(_pf.dominant_pct|num(0)) }}%</strong> · baisse {{ '%.1f'|format(_pf.cut_pct|num(0)) }}% · hausse {{ '%.1f'|format(_pf.hike_pct|num(0)) }}%</p>
  {% endif %}
  {% if polymarket_facts.extra_markets %}
  <p style="font-size:10px;color:#5a5852;margin:{% if polymarket_facts.fed_bars %}6px{% else %}10px{% endif %} 0 0 0;{% if not polymarket_facts.fed_bars %}border-top:0.5px solid #f0efe8;padding-top:8px;{% endif %}"><span style="font-weight:600;color:#1a1a18;">Autres marchés :</span> {% for m in polymarket_facts.extra_markets %}{{m.question}} <strong>{{ '%.0f'|format(m.probability_pct|num(0)) }}%</strong>{% if not loop.last %} · {% endif %}{% endfor %}</p>
  {% endif %}
  {% endif %}
</div>
{% endif %}

{# ════════ BLOC 4 · CE QUI A ÉVOLUÉ (✗ ✓ → ↑) ════════ #}
{% if market_changes %}
{% set _ico = {'invalidated':['✗','#A32D2D','INVALIDÉ'],'confirmed':['✓','#3B6D11','CONFIRMÉ'],'unchanged':['→','#8a8880','INCHANGÉ'],'new':['↑','#0C447C','NOUVEAU']} %}
{% set _tagcol = {'Catalyseur':['#EAF3DE','#27500A'],'Risque':['#FCEBEB','#791F1F'],'Macro':['#EEF2F7','#0C447C'],'Géopo':['#F3EEF7','#5B2A86'],'Info':['#F1EFE8','#5a5852']} %}
<h2 style="margin:1.5rem 0 0.5rem 0;font-size:17px;font-weight:500;">Ce qui a évolué côté marché</h2>
<div style="background:#f5f4ee;border-radius:12px;padding:12px 16px;margin-bottom:1.5rem;">
  {% for c in market_changes %}
  {% set _m = _ico.get(c.status, ['•','#5a5852','']) %}
  {% set _tc2 = _tagcol.get(c.tag, ['#F1EFE8','#5a5852']) %}
  <p style="margin:0 0 {{ '10px' if not loop.last else '0' }} 0;font-size:13px;line-height:1.55;">
    <span style="color:{{_m[1]}};font-weight:700;">{{_m[0]}} {{_m[2]}}</span>{% if c.tag %} <span style="display:inline-block;background:{{_tc2[0]}};color:{{_tc2[1]}};font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;padding:1px 5px;border-radius:3px;vertical-align:middle;">{{c.tag}}</span>{% endif %} · {{c.description|md}}{% if c.source %} <span style="color:#8a8880;font-size:11px;">· {{c.source}}</span>{% endif %}
  </p>
  {% endfor %}
</div>
{% endif %}

{# ════════ BLOC 5 · CE QUI EST TOMBÉ DEPUIS CE MATIN (news) ════════ #}
{% if news_today %}
<h2 style="margin:1.5rem 0 0.5rem 0;font-size:17px;font-weight:500;">Ce qui est tombé depuis ce matin</h2>
<div style="margin-bottom:1.5rem;">
  {% for n in news_today %}
  <div style="border-left:2px solid #e5e4dc;padding:0 0 0 12px;margin-bottom:{{ '12px' if not loop.last else '0' }};">
    <p style="margin:0;font-size:13px;font-weight:500;line-height:1.4;">{{n.title}}</p>
    <p style="margin:3px 0 0 0;font-size:11px;color:#5a5852;line-height:1.5;">{% if n.source %}{{n.source}}{% endif %}{% if n.time %} · {{n.time}}{% endif %} — {{n.impact|md}}{% if n.status %} <span style="color:{% if n.status == 'actionnable' %}#BA7517{% else %}#8a8880{% endif %};">({{n.status}})</span>{% endif %}</p>
  </div>
  {% endfor %}
</div>
{% elif intraday_news %}
<h2 style="margin:1.5rem 0 0.5rem 0;font-size:17px;font-weight:500;">Ce qui est tombé depuis ce matin</h2>
<div style="margin-bottom:1.5rem;">
  {% for n in intraday_news %}
  <div style="border-left:2px solid #e5e4dc;padding:0 0 0 12px;margin-bottom:{{ '12px' if not loop.last else '0' }};">
    <p style="margin:0;font-size:13px;font-weight:500;line-height:1.4;">{{n.title}}</p>
    <p style="margin:3px 0 0 0;font-size:11px;color:#5a5852;">{% if n.source %}{{n.source}}{% endif %}{% if n.timestamp %} · {{n.timestamp}}{% endif %}{% if n.impact %} — {{n.impact|md}}{% endif %}</p>
  </div>
  {% endfor %}
</div>
{% endif %}

{# ════════ BLOC 6 · RECOS DU MATIN · BILAN SOIR (Python, 1 ligne/actif) ════════ #}
{# v19/W-B12 — espérance mathématique des recos (présente dans les 3 mails).
   v26 (E-A8/E-B11) — MASQUÉE quand il n'y a NI historique NI reco active : deux
   placeholders vides qui se télescopaient (« disponible après 5 recos » juste
   au-dessus de « Aucune reco active ») = bruit pur. #}
{% set _exp_has_value = expectancy and expectancy.available and (expectancy.expectancy_pct is not none) %}
{% if _exp_has_value or reco_bilan %}
<p style="font-size:11px;color:#5a5852;margin:1.5rem 0 0 0;">Espérance mathématique des recos : {% if _exp_has_value %}<strong style="color:{% if (expectancy.expectancy_pct|num(0)) > 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{{ '+' if (expectancy.expectancy_pct|num(0)) >= 0 else '' }}{{expectancy.expectancy_pct}}% / reco</strong>{% else %}<span style="color:#8a8880;font-style:italic;">disponible après 5 recos clôturées</span>{% endif %}</p>
{% endif %}
{% if reco_bilan %}
{# v28 (E-A5) — statut « stable » : proche de l'entrée = pas d'alarme. #}
{% set _st = {'on_track':['✓ on track','#EAF3DE','#27500A'],'stable':['● stable','#f5f4ee','#5a5852'],'under_pressure':['⚠ sous pression','#FAEEDA','#412402'],'invalidated':['✗ invalidé','#FCEBEB','#791F1F'],'pending':['• en cours','#f5f4ee','#8a8880']} %}
<h2 style="margin:1.5rem 0 0.5rem 0;font-size:17px;font-weight:500;">Recos du matin · bilan soir</h2>
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:12px;padding:0.5rem 0.75rem;margin-bottom:1.5rem;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;font-size:12px;">
    <tr style="color:#8a8880;font-size:9px;text-transform:uppercase;letter-spacing:0.5px;">
      <td style="padding:6px 4px;width:13%;">Actif</td>
      <td style="padding:6px 4px;width:11%;">Reco</td>
      <td style="padding:6px 4px;width:12%;text-align:right;">Entrée</td>
      <td style="padding:6px 4px;width:12%;text-align:right;">Cible</td>
      <td style="padding:6px 4px;width:12%;text-align:right;">Actuel</td>
      <td style="padding:6px 4px;width:9%;text-align:right;">Δ vs entrée</td>
      <td style="padding:6px 4px;width:31%;">Statut</td>
    </tr>
    {% for r in reco_bilan %}
    {% set _s = _st.get(r.status, ['—','#f5f4ee','#8a8880']) %}
    <tr style="border-top:0.5px solid #f0efe8;">
      <td style="padding:7px 4px;font-weight:700;vertical-align:top;">{{r.asset}}{% if r.confidence %} <span style="font-weight:400;color:#8a8880;font-size:9px;white-space:nowrap;">(C.{{ r.confidence|round|int }}%)</span>{% endif %}</td>
      <td style="padding:7px 4px;color:#5a5852;vertical-align:top;">{{r.action}}</td>
      <td style="padding:7px 4px;color:#5a5852;text-align:right;white-space:nowrap;vertical-align:top;">{{ r.entry|fmt_money }}</td>
      <td style="padding:7px 4px;color:#5a5852;text-align:right;white-space:nowrap;vertical-align:top;">{{ r.target|fmt_money }}</td>
      <td style="padding:7px 4px;color:#2a2a2a;font-weight:600;text-align:right;white-space:nowrap;vertical-align:top;">{{ r.current|fmt_money }}</td>
      <td style="padding:7px 4px;text-align:right;white-space:nowrap;vertical-align:top;{% if r.delta_pct is not none %}color:{% if (r.delta_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};font-weight:600;{% else %}color:#8a8880;{% endif %}">{% if r.delta_pct is not none %}{{ r.delta_pct|fmt_pct }}{% else %}—{% endif %}</td>
      <td style="padding:7px 4px;vertical-align:top;"><span style="background:{{_s[1]}};color:{{_s[2]}};padding:2px 8px;border-radius:6px;font-size:11px;font-weight:600;white-space:nowrap;">{{_s[0]}}</span>{% if r.reason %}<div style="color:#8a8880;font-size:10px;line-height:1.3;margin-top:3px;">{{ r.reason }}</div>{% endif %}</td>
    </tr>
    {% endfor %}
  </table>
  <p style="font-size:9px;color:#a8a6a0;margin:6px 4px 2px 4px;font-style:italic;">Δ = variation depuis le prix d'entrée de la thèse · « Actuel » = cours à l'heure d'envoi du mail.</p>
</div>
{% else %}
<h2 style="margin:1.5rem 0 0.5rem 0;font-size:17px;font-weight:500;">Recos du matin · bilan soir</h2>
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:12px;padding:0.75rem;margin-bottom:1.5rem;">
  <p style="font-size:12px;color:#8a8880;margin:0;font-style:italic;">Aucune reco active aujourd'hui — rien à arbitrer.</p>
</div>
{% endif %}

{# ════════ BLOC 7 · NIVEAUX À SURVEILLER CETTE NUIT ════════ #}
{% if levels_tonight %}
{% set _lt = {'support':['support','#FAEEDA','#412402'],'resistance':['résistance','#EAF3DE','#27500A'],'critical':['critique','#FCEBEB','#791F1F'],'threshold':['seuil','#E6F1FB','#0C447C']} %}
{# v28 (E-A1) — « cette nuit » seulement quand le run est bien un run du soir. #}
<h2 style="margin:1.5rem 0 0.5rem 0;font-size:17px;font-weight:500;">{{ header.levels_window_label or "Niveaux à surveiller cette nuit" }}</h2>
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:12px;padding:0.5rem 0.75rem;margin-bottom:1.5rem;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;font-size:12px;">
    {# v16.1 — UNE ligne par actif : tous ses niveaux (support/résistance/seuil)
       sont regroupés, plus de doublons « TAO » sur plusieurs lignes. #}
    {% for _asset, _levels in levels_tonight|groupby('asset') %}
    <tr style="{% if not loop.first %}border-top:0.5px solid #f0efe8;{% endif %}">
      <td style="padding:8px 6px 8px 4px;font-weight:700;white-space:nowrap;width:56px;vertical-align:top;">{{_asset}}
        {# v19/E-A14/V18-E9 : prix de référence sous le symbole (BTC/ETH) pour
           situer les niveaux — l'Evening donnait des niveaux ETH sans prix actuel. #}
        {% set _ap = (evening_macro.btc_price if _asset == 'BTC' else (evening_macro.eth_price if _asset == 'ETH' else none)) %}
        {% if _ap %}<div style="font-size:9px;color:#8a8880;font-weight:500;">{{ _ap|fmt_price }}</div>{% endif %}
      </td>
      <td style="padding:8px 4px;vertical-align:top;">
        {% for lv in _levels %}
        {% set _t = _lt.get(lv.type, ['niveau','#f5f4ee','#5a5852']) %}
        <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;"><tr>
          <td style="padding:1px 8px 1px 0;font-weight:600;white-space:nowrap;width:64px;vertical-align:top;">{{lv.level}}</td>
          <td style="padding:1px 8px 1px 0;white-space:nowrap;width:74px;vertical-align:top;"><span style="background:{{_t[1]}};color:{{_t[2]}};padding:1px 7px;border-radius:6px;font-size:10px;font-weight:600;">{{_t[0]}}</span></td>
          <td style="padding:1px 0 {% if not loop.last %}5px{% else %}1px{% endif %} 0;color:#5a5852;line-height:1.4;">{{lv.trigger|md}}</td>
        </tr></table>
        {% endfor %}
        {# v26 (E-B5) — readout technique calculé (RSI/MACD/Bollinger/ATR/volume)
           sous les niveaux de l'actif : l'analyse profonde, sans blabla. #}
        {% if levels_readout and levels_readout.get(_asset) %}
        <p style="margin:4px 0 0 0;font-size:10px;color:#8a8880;line-height:1.4;">{{ levels_readout.get(_asset) }}</p>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </table>
</div>
{% endif %}

{# ════════ BLOC 7bis (v15) · ACTIONS À POSER CE SOIR — fond sombre ════════ #}
{% if actions_tonight %}
<div style="background:#1f1e1d;border-radius:12px;padding:14px 16px;margin-bottom:1.5rem;">
  <p style="font-size:11px;color:#8a8880;margin:0 0 8px 0;text-transform:uppercase;letter-spacing:0.5px;font-weight:500;">Actions à poser ce soir</p>
  {% for a in actions_tonight %}
  <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;margin-bottom:{% if not loop.last %}10px{% else %}0{% endif %};"><tr>
    <td style="width:20px;vertical-align:top;font-size:12px;line-height:1.5;color:#e5b567;">☐</td>
    <td style="font-size:13px;line-height:1.5;color:#f5f4ee;">
      {% if a is mapping %}
      <span style="font-weight:600;">{{a.action|md}}</span>
      {% if a.rationale %}<br><span style="font-size:11px;color:#c9c7c0;line-height:1.45;">↳ {{a.rationale|md}}</span>{% endif %}
      {% if a.rebuy %}<br><span style="font-size:11px;color:#9fbf7f;line-height:1.45;">↻ Rachat visé : {{a.rebuy|md}}</span>{% endif %}
      {% if a.horizon %}<br><span style="font-size:10px;color:#8a8880;font-style:italic;">{{a.horizon|md}}</span>{% endif %}
      {% else %}{{a|md}}{% endif %}
    </td>
  </tr></table>
  {% endfor %}
</div>
{% endif %}

{# ════════ BLOC 8 · DEMAIN MATIN · CHECK LIST ════════ #}
{% set _tc = tomorrow_checklist or {} %}
{% if _tc.calendar or _tc.checks or _tc.scenario or _tc.invalidation or tomorrow_macro_events %}
<div style="background:#1a1a18;border-radius:12px;padding:14px 16px;margin-bottom:1.5rem;">
  {# v28 (E-A1) — titre calculé selon l'heure du run (rattrapage matinal ≠ soir). #}
  <p style="font-size:11px;color:#8a8880;margin:0 0 10px 0;text-transform:uppercase;letter-spacing:0.5px;font-weight:500;">{{ header.checklist_title or "Demain matin · check list" }}</p>
  {# v26 (E-A6/E-B6) — les événements J0 déjà tombés sont exclus côté Python ;
     un événement encore à venir aujourd'hui porte « ce soir » + son heure. #}
  <p style="margin:0 0 7px 0;font-size:12px;line-height:1.55;color:#f5f4ee;">📅 <span style="color:#8a8880;">À l'agenda :</span> {% if tomorrow_macro_events %}{% for e in tomorrow_macro_events %}{% if e.when %}<span style="color:#e5b567;">{{e.when}}</span> {% endif %}{{e.label}}{% if e.time %} <span style="color:#8a8880;">{{e.time}}</span>{% endif %}{% if e.date_label %} <span style="color:#8a8880;">· {{e.date_label}}</span>{% endif %}{% if not loop.last %} · {% endif %}{% endfor %}{% elif _tc.calendar %}{{_tc.calendar}}{% else %}Pas d'événement macro majeur dans les 48h.{% endif %}</p>
  {% if _tc.checks %}<p style="margin:0 0 7px 0;font-size:12px;line-height:1.55;color:#f5f4ee;">📊 <span style="color:#8a8880;">À vérifier :</span> {{_tc.checks|md}}</p>{% endif %}
  {% if _tc.scenario %}<p style="margin:0 0 7px 0;font-size:12px;line-height:1.55;color:#f5f4ee;">🎯 <span style="color:#8a8880;">Scénario probable :</span> {{_tc.scenario|md}}</p>{% endif %}
  {% if _tc.invalidation %}<p style="margin:0;font-size:12px;line-height:1.55;color:#f5f4ee;">⚠ <span style="color:#8a8880;">Invalidation :</span> {{_tc.invalidation|md}}</p>{% endif %}
</div>
{% endif %}

{# ── Angle mort (discret, 1 ligne si critique) ── #}
{% if blind_spots %}
<p style="font-size:11px;color:#8a8880;font-style:italic;margin:0 0 1rem 0;">Angle mort · {{blind_spots}}</p>
{% endif %}

{# ════════ BLOC 9 · FOOTER ════════ #}
<div style="border-top:0.5px solid #e5e4dc;padding-top:1rem;margin-top:0.5rem;">
  {% if _degraded or footer.note %}
  <p style="font-size:11px;color:#BA7517;margin:0 0 6px 0;font-weight:600;">⚠️ {{ footer.note or "Rapport généré en mode dégradé." }}</p>
  {% endif %}
  <p style="font-size:11px;color:#8a8880;margin:0;">Prochain rapport · {{ footer.next_report_at or ("demain " ~ (footer.next_morning_time or '08h30')) }} · format complet</p>
  {# v28 (E-A1) — salutation calculée : plus de « Bonne soirée. » à 09h46. #}
  <p style="font-size:11px;color:#8a8880;margin:4px 0 0 0;">{{ header.closing_greeting or "Bonne soirée." }}</p>
  {# v27 (AF5) — légende unique des codes couleur (cohérente sur les 3 mails). #}
  <p style="font-size:9px;color:#8a8880;margin:6px 0 0 0;"><span style="color:#3B6D11;">■</span> achat/haussier · <span style="color:#A32D2D;">■</span> vente/baissier · <span style="color:#BA7517;">■</span> prudence</p>
  <p style="font-size:9px;color:#b5b3ab;margin:8px 0 0 0;">Crypto Analyst Pro · {{app_version or "v15"}}</p>
  <p style="font-size:9px;color:#b5b3ab;margin:2px 0 0 0;">{{ disclaimer or "Analyse informative, pas un conseil en investissement. Fais tes propres recherches avant toute décision." }}</p>
</div>
