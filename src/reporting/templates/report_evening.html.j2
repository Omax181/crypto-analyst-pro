{# Rapport SOIR v14 — dashboard de fin de journée, 8 blocs scannables.
   Tables mail-safe (flex/grid non supportés Gmail/Outlook), styles inline,
   codes couleur systématiques. Aucune dépendance JS. #}

{# ── MACRO FLÈCHE 24h (v14) — verte hausse / rouge baisse / grise stable.
   Seuil adaptatif : < 0,5% de la valeur de l'item = stable. Pour une variation
   déjà en %, passer value=100 et delta=variation%. Rend "" si delta/valeur
   manquant. #}
{% macro arrow24(value, delta) -%}
{%- set v = value|num(0) -%}
{%- set d = delta|num(none) -%}
{%- if d is not none and v and v != 0 -%}
  {%- set pct = (d if d >= 0 else -d) / (v if v >= 0 else -v) * 100 -%}
  {%- if pct < 0.15 -%}<span style="color:#8a8880;font-size:11px;"> ▬</span>
  {%- elif d > 0 -%}<span style="color:#3B6D11;font-size:11px;"> ▲</span>
  {%- else -%}<span style="color:#A32D2D;font-size:11px;"> ▼</span>
  {%- endif -%}
{%- endif -%}
{%- endmacro %}

{# v18 (E-A7) — Δ24h CHIFFRÉ (%) pour la tuile BTC du soir, comme le matin. #}
{% macro pct24(change_pct) -%}
{%- set c = change_pct|num(none) -%}
{%- if c is not none -%}
  {%- if (c if c >= 0 else -c) < 0.05 -%}<span style="color:#8a8880;font-size:10px;"> 0.0%</span>
  {%- elif c > 0 -%}<span style="color:#3B6D11;font-size:10px;"> +{{ '%.1f'|format(c) }}%</span>
  {%- else -%}<span style="color:#A32D2D;font-size:10px;"> −{{ '%.1f'|format(-c) }}%</span>
  {%- endif -%}
{%- endif -%}
{%- endmacro %}

{# ════════ BLOC 1 · HEADER ════════ #}
<div style="border-bottom:0.5px solid #e5e4dc;padding-bottom:1rem;margin-bottom:1.5rem;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;">
    <tr>
      <td style="vertical-align:top;">
        <p style="font-size:12px;color:#5a5852;margin:0 0 4px 0;">{{header.time_casablanca or header.date}}</p>
        <h1 style="margin:0;font-size:25px;font-weight:500;line-height:1.2;">Veille crypto · soir</h1>
        <p style="font-size:12px;color:#8a8880;margin:6px 0 0 0;">Complément au rapport matin{% if header.timing_line %} · {{header.timing_line}}{% else %}{% if header.morning_time_label %} ({{header.morning_time_label}}){% endif %}{% if header.since_morning_label %} · {{header.since_morning_label}}{% endif %}{% endif %}</p>
      </td>
      <td style="vertical-align:top;text-align:right;white-space:nowrap;padding-left:12px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Portefeuille</p>
        <p style="font-size:16px;font-weight:500;margin:2px 0 0 0;">{% if portfolio_snapshot.value_usd %}{{ portfolio_snapshot.value_usd|fmt_price }}{% else %}—{% endif %}</p>
        {# v26 (E-A7/E-B7) — MÊME précision que le Bilan (2 décimales) : le header
           disait « +2.1% » et le bilan « +2.15% » pour le MÊME chiffre. #}
        {% if (portfolio_snapshot.change_since_morning_pct|default(none)) is not none %}{% set _csm = portfolio_snapshot.change_since_morning_pct|num(0) %}<p style="font-size:10px;color:{% if _csm >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};margin:0;">{{ '+' if _csm >= 0 else '−' }}{{ '%.2f'|format(_csm|abs) }}% depuis matin</p>{% endif %}
        {# v23 — winrate 30j en tête (une fois, comme le matin). #}
        {% set _wr_parts_e = (header.win_rate_total or '0/0').split('/') %}
        {% set _wr_total_e = (_wr_parts_e[1]|num(0)) if (_wr_parts_e|length > 1) else 0 %}
        {% set _wr_val_e = header.win_rate_30d|num(none) %}
        {# v28 (M-A15) — < 5 clôtures : « en calibration (2/2) », plus de %
           flatteur non calibré (aligné sur le header du matin). #}
        <p style="font-size:10px;color:#8a8880;margin:8px 0 0 0;">Win rate 30j · <span style="font-weight:600;color:{% if _wr_total_e >= 5 and _wr_val_e is not none and _wr_val_e >= 50 %}#3B6D11{% elif _wr_total_e >= 5 and _wr_val_e is not none and _wr_val_e < 50 %}#A32D2D{% else %}#5a5852{% endif %};">{% if _wr_total_e < 1 or _wr_val_e is none %}— pas encore d'historique{% elif _wr_total_e < 5 %}en calibration ({{header.win_rate_total}}){% else %}{{ '%.0f'|format(_wr_val_e) }}%{% endif %}</span></p>
      </td>
    </tr>
  </table>
</div>

{# ── v27 (ME1) — RÉGIME DE MARCHÉ (cohérence cross-mail avec matin/weekly). ── #}
{% if market_regime and market_regime.available %}
{% set _rge = market_regime.regime %}
{% set _rgebg = '#EAF3DE' if _rge == 'bull' else ('#FCEBEB' if _rge == 'bear' else ('#FAEEDA' if _rge == 'transition' else '#EEF2F7')) %}
