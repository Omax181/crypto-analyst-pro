{# ════════ BLOC 2 · BILAN DU JOUR (4 KPIs + movers + mini-barre) ════════ #}
{% if daily_pnl %}
{% set _pnl_pct = daily_pnl.day_change_pct %}
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:12px;padding:1rem 1.25rem;margin-bottom:1.5rem;">
  <p style="font-size:12px;font-weight:500;color:#1a1a18;margin:0 0 10px 0;text-transform:uppercase;letter-spacing:0.5px;">Bilan du jour</p>
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;table-layout:fixed;">
    <tr>
      <td style="width:25%;vertical-align:top;padding-right:6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">P&amp;L depuis matin</p>
        {# v15 (audit P0) : 2 décimales — « +0.0% avec +$1 » mangeait le
           signal ; « neutre » explicite quand le mouvement est réellement nul. #}
        <p style="font-size:18px;font-weight:700;margin:2px 0 0 0;color:{% if daily_pnl.day_change_label == 'neutre' %}#8a8880{% elif (_pnl_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{% if _pnl_pct is not none %}{% set _pv = _pnl_pct|num(0) %}{{ '+' if _pv >= 0 else '−' }}{{ '%.2f'|format(_pv|abs) }}%{% else %}—{% endif %}</p>
        {% if daily_pnl.day_change_label == 'neutre' %}<p style="font-size:9px;color:#8a8880;margin:0;">journée neutre</p>{% endif %}
      </td>
      <td style="width:25%;vertical-align:top;padding-right:6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">En $</p>
        <p style="font-size:18px;font-weight:500;margin:2px 0 0 0;color:{% if daily_pnl.day_change_label == 'neutre' %}#8a8880{% elif (daily_pnl.day_change_usd|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{% set _d = daily_pnl.day_change_usd|num(none) %}{% if _d is not none %}{{ '+' if _d >= 0 else '−' }}${% if _d|abs < 10 %}{{ '%.2f'|format(_d|abs) }}{% else %}{{ '{:,.0f}'.format(_d|abs) }}{% endif %}{% else %}—{% endif %}</p>
      </td>
      <td style="width:25%;vertical-align:top;padding-right:6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Valeur PTF</p>
        <p style="font-size:18px;font-weight:500;margin:2px 0 0 0;">{% if daily_pnl.value_usd %}{{ daily_pnl.value_usd|fmt_price }}{% else %}—{% endif %}</p>
      </td>
      <td style="width:25%;vertical-align:top;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Santé PTF</p>
        {% if health_score and (health_score.score is not none) %}
        <p style="font-size:18px;font-weight:700;margin:2px 0 0 0;color:{{health_score.level_color or '#1a1a18'}};">{{health_score.score}}<span style="font-size:11px;color:#8a8880;font-weight:400;">/10</span></p>
        <p style="font-size:9px;color:{{health_score.level_color or '#8a8880'}};margin:0;">{{health_score.level}}</p>
        {% else %}<p style="font-size:18px;font-weight:500;margin:2px 0 0 0;color:#8a8880;">—</p>{% endif %}
      </td>
    </tr>
  </table>
  {# v23 — santé PTF : mini-barres (vert = sain) comme le matin ; si la santé
     n'a pas bougé depuis le matin (±0.3), on REMPLACE par une note d'1 ligne. #}
  {% if health_unchanged_since_morning and health_unchanged_since_morning.active %}
  <p style="margin:10px 0 0 0;font-size:11px;color:#5a5852;background:#f5f4ee;border-radius:6px;padding:7px 12px;">↔ {{ health_unchanged_since_morning.note }}</p>
  {% elif health_score and health_score.axes %}
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;margin-top:10px;">
    {% for ax in health_score.axes %}
    {% set _w = ((ax.score / ax.max * 100) if ax.max else 0)|round(0)|int %}
    <tr>
      <td style="font-size:10px;color:#5a5852;white-space:nowrap;padding:1px 8px 1px 0;width:110px;">{{ax.label}}</td>
      <td style="vertical-align:middle;padding:1px 8px 1px 0;">
        <div style="background:#eceae2;border-radius:3px;height:6px;width:100%;max-width:160px;">
          <div style="background:{% if _w >= 65 %}#3B6D11{% elif _w >= 40 %}#BA7517{% else %}#A32D2D{% endif %};border-radius:3px;height:6px;width:{{[_w, 2]|max}}%;"></div>
        </div>
      </td>
      <td style="font-size:10px;color:#8a8880;white-space:nowrap;padding:1px 0;width:48px;">{{ax.score}}/10</td>
    </tr>
    {% endfor %}
  </table>
  {% endif %}
  {% if health_score and (health_score.driver or health_score.improve) and not (health_unchanged_since_morning and health_unchanged_since_morning.active) %}
  <div style="margin-top:8px;font-size:10px;line-height:1.5;color:#5a5852;">
    {% if health_score.driver %}<p style="margin:0 0 2px 0;">{{health_score.driver}}</p>{% endif %}
    {% if health_score.improve %}<p style="margin:0;color:#1a1a18;"><span style="font-weight:600;">Pour l'améliorer :</span> {{health_score.improve}}</p>{% endif %}
  </div>
  {% endif %}
  {% if _pnl_pct is not none %}
  {% set _w = ((_pnl_pct|num(0))|abs * 10) %}{% set _w = 100 if _w > 100 else _w %}
  <div style="background:#e5e4dc;border-radius:4px;height:6px;width:100%;margin-top:10px;">
    <div style="background:{% if (_pnl_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};border-radius:4px;height:6px;width:{{ '%.0f'|format(_w) }}%;"></div>
  </div>
  {% endif %}
  {# Top mouvements (poussières <10$ déjà exclues côté Python). v26 (E-A11) :
     fenêtre 24h explicitement distinguée du P&L « depuis matin » du bilan. #}
  {% if daily_pnl.top_movers %}
  <p style="font-size:9px;color:#8a8880;margin:12px 0 4px 0;text-transform:uppercase;letter-spacing:0.5px;border-top:0.5px solid #f0efe8;padding-top:10px;">Top mouvements · 24h glissant <span style="text-transform:none;letter-spacing:0;font-style:italic;">(fenêtre 24h ≠ P&amp;L depuis matin)</span></p>
  <p style="margin:0;font-size:12px;line-height:1.7;">
    {# v28 (E-A4) — l'impact $ n'apparaît que s'il est SIGNIFICATIF (≥ 5 $) :
       les « (−$1) / (−$0) » du 07/07 n'apportaient rien. #}
    {% for m in daily_pnl.top_movers %}<span style="display:inline-block;margin-right:14px;white-space:nowrap;"><strong>{{m.symbol}}</strong> <span style="color:{% if (m.change|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{{ '+' if (m.change|num(0)) >= 0 else '' }}{{m.change}}%</span>{% set _pu = m.pnl_usd|num(0) %}{% if _pu|abs >= 5 %} <span style="color:#8a8880;font-size:11px;">({{ '+' if _pu >= 0 else '−' }}${{ '{:,.0f}'.format(_pu|abs) }})</span>{% endif %}</span>{% endfor %}
  </p>
  {% endif %}
</div>
{% endif %}

{# ════════ HEATMAP SOIR : SUPPRIMÉE en v16 — faisait doublon avec « Top
   mouvements » ci-dessus (et parfois s'en écartait). On garde uniquement la
   liste « Top mouvements », plus lisible. ════════ #}

{# ════════ BLOC 2bis · À RETENIR AUJOURD'HUI (puces typées, v16) ════════ #}
{% if delta_summary %}
<div style="background:#1a1a18;border-radius:12px;padding:14px 16px;margin-bottom:1.5rem;">
  <p style="font-size:10px;color:#8a8880;margin:0 0 8px 0;text-transform:uppercase;letter-spacing:0.5px;font-weight:500;">À retenir aujourd'hui</p>
  {# v23.x (Omar) — puce neutre • par défaut ; ⚠️ jaune RÉSERVÉ aux points
     URGENTS/IMPORTANTS (icon ⚠). Plus de ✓/✗ dans la colonne d'icônes. #}
  {% for d in delta_summary %}
  {% if d is mapping %}
  {% set _warn = (d.icon or '') in ['⚠', '⚠️'] %}
  <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;"><tr>
    <td style="width:22px;vertical-align:top;font-size:13px;line-height:1.55;color:{% if _warn %}#e5b567{% else %}#b5b3ab{% endif %};">{% if _warn %}⚠️{% else %}•{% endif %}</td>
    <td style="font-size:13px;line-height:1.55;color:#f5f4ee;">{{ d.text|md }}</td>
  </tr></table>
  {% else %}
  <p style="margin:0 0 {{ '7px' if not loop.last else '0' }} 0;font-size:13px;line-height:1.5;color:#f5f4ee;">→ {{ d|md }}</p>
  {% endif %}
  {% endfor %}
</div>
{% endif %}

