  {% set _phasemap = {'capitulation':['Capitulation','#0E6B5E','#E1F5EE'],'accumulation':['Accumulation','#27500A','#EAF3DE'],'expansion':['Expansion','#0C447C','#E6F1FB'],'distribution':['Distribution','#8A5A12','#F4E4C1']} %}
  {% set _actmap = {'renforcer':['Renforcer','#27500A','#EAF3DE'],'garder':['Garder','#33312e','#F1EFE8'],'alléger':['Alléger','#8A5A12','#F4E4C1'],'alleger':['Alléger','#8A5A12','#F4E4C1'],'sortir':['Sortir','#791F1F','#FCEBEB']} %}
  {% set _h30map = {'validated':['✓ validée','#3B6D11'],'invalidated':['✗ invalidée','#A32D2D'],'in_progress':['● en cours','#0C447C'],'neutral':['= neutre','#8a8880']} %}
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;font-size:11px;">
    <tr style="background:#f5f4ee;color:#5a5852;">
      <th style="text-align:left;font-size:10px;text-transform:uppercase;font-weight:500;padding:6px 6px;letter-spacing:0.3px;">Actif</th>
      <th style="text-align:right;font-size:10px;text-transform:uppercase;font-weight:500;padding:6px 6px;letter-spacing:0.3px;">Prix · PRU</th>
      <th style="text-align:left;font-size:10px;text-transform:uppercase;font-weight:500;padding:6px 6px;letter-spacing:0.3px;">Horizon 30j</th>
      {# v28 (W-A13) — colonne « Action » SUPPRIMÉE : elle répétait « Horizon
         30j » ligne à ligne (RENFORCER=Renforcer, pas de reco=Sortir). Le
         geste vit en fin de ligne ⚙, une seule fois. #}
      <th style="text-align:left;font-size:10px;text-transform:uppercase;font-weight:500;padding:6px 6px;letter-spacing:0.3px;">Long terme</th>
    </tr>
    {% for r in positions_review %}
    {% set _ph = _phasemap.get(r.lt_status, [r.lt_status or '—','#5a5852','#F1EFE8']) %}
    {% set _ac = _actmap.get((r.action or '')|lower, [r.action or '—','#5a5852','#F1EFE8']) %}
    <tr style="border-top:0.5px solid #e5e4dc;">
      <td style="padding:6px 6px;vertical-align:top;"><span style="font-size:12px;font-weight:700;color:#1a1a18;">{{r.asset}}</span>{% if r.conviction %}<br><span style="font-size:8px;color:#27500A;text-transform:uppercase;letter-spacing:0.3px;">★ cœur</span>{% else %}<br><span style="font-size:8px;color:#8a8880;text-transform:uppercase;letter-spacing:0.3px;">satellite</span>{% endif %}</td>
      <td style="padding:6px 6px;text-align:right;vertical-align:top;white-space:nowrap;"><span style="font-weight:600;color:#1a1a18;">{{ r.current_price|fmt_price }}</span>{% if r.pru_pct is not none %}<br><span style="font-size:10px;color:{% if (r.pru_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{{ r.pru_pct|fmt_pct }} <span style="color:#8a8880;">/PRU</span></span>{% endif %}</td>
      <td style="padding:6px 6px;vertical-align:top;">{% if r.h30 and r.h30.reco %}{% set _hs = _h30map.get(r.h30.status, ['—','#8a8880']) %}<span style="background:{% if r.h30.reco in ['RENFORCER','BUY'] %}#EAF3DE{% elif r.h30.reco in ['ALLÉGER','ALLEGER','SELL','SORTIR'] %}#FCEBEB{% else %}#E6F1FB{% endif %};color:{% if r.h30.reco in ['RENFORCER','BUY'] %}#27500A{% elif r.h30.reco in ['ALLÉGER','ALLEGER','SELL','SORTIR'] %}#791F1F{% else %}#0C447C{% endif %};font-size:9px;padding:1px 5px;border-radius:3px;font-weight:700;">{{r.h30.reco}}</span><br><span style="font-size:10px;color:{{_hs[1]}};">{% if r.h30.delta_pct is not none %}{{ r.h30.delta_pct|fmt_pct }} · {% endif %}{{_hs[0]}}</span>{% else %}<span style="font-size:10px;color:#b5b3ab;">pas de reco active</span>{% endif %}</td>
      {# v26 (W-A16) — une cible ≥ +250% est une CIBLE DE CYCLE (reconquête
         ATH), pas un objectif 6-12 mois : le libellé le dit.
         v28 (W-A11) — la FOURCHETTE déterministe (asset_plan.target_cycle,
         identique aux fiches du matin) prime sur la cible LLM. #}
      <td style="padding:6px 6px;vertical-align:top;"><span style="display:inline-block;padding:1px 7px;border-radius:10px;background:{{_ph[2]}};color:{{_ph[1]}};font-weight:600;font-size:9px;">{{_ph[0]}}</span>{% if r.lt_target_high %}<br><span style="font-size:10px;color:#5a5852;">{% if r.lt_target_kind == 'cycle' %}cible cycle{% else %}cible{% endif %} {{ r.lt_target_low|fmt_price }}–{{ r.lt_target_high|fmt_price }}{% set _ltp = r.lt_target_pct|num(none) %}{% if _ltp is not none %} <span style="color:{% if _ltp >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">({{ '+' if _ltp >= 0 else '' }}{{_ltp|int}}%)</span>{% endif %}</span>{% elif r.lt_target %}<br><span style="font-size:10px;color:#5a5852;">{% if r.lt_target_kind == 'cycle' %}cible cycle{% else %}cible{% endif %} {{ r.lt_target|fmt_price }}{% set _ltp = r.lt_target_pct|num(none) %}{% if _ltp is not none %} <span style="color:{% if _ltp >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">({{ '+' if _ltp >= 0 else '' }}{{_ltp|int}}%)</span>{% endif %}</span>{% else %}<br><span style="font-size:10px;color:#b5b3ab;">cible à définir</span>{% endif %}</td>
    </tr>
    {% if r.analysis or _ac[0] != '—' %}<tr><td colspan="4" style="padding:0 6px 6px 6px;color:#8a8880;font-size:10px;line-height:1.35;">{% if r.analysis %}⚙ {{ r.analysis }}{% endif %}{% if _ac[0] != '—' %} <span style="color:{{_ac[1]}};font-weight:700;">→ {{_ac[0]}}</span>{% endif %}</td></tr>{% endif %}
    {% endfor %}
  </table>
  <p style="font-size:9px;color:#a8a6a0;margin:8px 6px 0 6px;font-style:italic;">Horizon 30j = perf de la reco en cours (Δ depuis l'entrée) · Long terme = phase de cycle + cible 6-12m — « cible cycle » = reconquête de l'ATH, horizon &gt; 12m · ★ cœur = conviction (vs satellite à offloader sur force).</p>
</div>
{% endif %}

{# ── SOURCES & ANGLES MORTS (fusion v23.x — Omar : « angles morts récurrents »
   et « sources actives / lacunes structurelles » parlent du MÊME sujet, la
   couverture des sources et ses trous → UN seul bloc, gain d'espace). Le suivi
   QUANTIFIÉ des sources en panne récurrente (X j/7, semaine sur semaine) est
   désormais une sous-section des lacunes, à côté du panorama LLM. ── #}
{% if sources_review or (blind_spots_weekly and blind_spots_weekly.entries) or (header.active_sources_count is not none) %}
<div style="background:#F1EFE8;border-radius:8px;padding:12px 14px;margin-bottom:1.5rem;font-size:12px;color:#5a5852;line-height:1.6;">
  <p style="margin:0 0 6px 0;font-weight:500;color:#1a1a18;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;">Sources &amp; angles morts récurrents · {{header.active_sources_count or 0}}{% if header.total_sources_count %} / {{header.total_sources_count}}{% endif %} actives</p>
  {% if sources_review.summary %}
  <p style="margin:6px 0 0 0;font-size:11px;color:#1a1a18;font-weight:500;">Sources actives</p>
  <div style="margin:2px 0 0 0;font-size:12px;color:#5a5852;">{{sources_review.summary|md}}</div>
  {% endif %}
  {% if sources_review.gaps or (blind_spots_weekly and blind_spots_weekly.entries) %}
  <p style="margin:8px 0 0 0;font-size:11px;color:#1a1a18;font-weight:500;">Lacunes &amp; angles morts récurrents</p>
  {% if sources_review.gaps %}<div style="margin:2px 0 0 0;font-size:12px;color:#5a5852;">{{sources_review.gaps|md}}</div>{% endif %}
  {% if blind_spots_weekly and blind_spots_weekly.entries %}
  {% for bs in blind_spots_weekly.entries %}
  <p style="margin:3px 0 0 0;font-size:11px;color:#5a5852;line-height:1.5;">• <span style="font-weight:500;">{{bs.source|humanize_source}}</span> indispo {{bs.days_down}} j/7{% if bs.prev_days_down is not none %} <span style="color:#8a8880;">(vs {{bs.prev_days_down}} j/7 sem. dernière)</span>{% endif %}{% if bs.note %} — {{bs.note}}{% endif %}</p>
  {% endfor %}
  {% if blind_spots_weekly.reading %}<p style="margin:6px 0 0 0;font-size:11px;color:#5a5852;line-height:1.5;">{{blind_spots_weekly.reading}}</p>{% endif %}
  {% endif %}
  {% endif %}
</div>
{% endif %}

{# ── FOOTER (heures Casablanca HH:MM, points 29-30-39) ── #}
<div style="border-top:0.5px solid #e5e4dc;padding-top:1rem;text-align:center;">
  {# Point 30 : matin = 08:30 (cron 30 7 * * *) ; point 29 : hebdo = dimanche 12:00. #}
  {% if _degraded or footer.note %}
  <p style="font-size:11px;color:#BA7517;margin:0 0 6px 0;font-weight:600;">⚠️ {{ footer.note or "Rapport généré en mode dégradé." }}</p>
  {% endif %}
  {# v26 (W-A12) — UNE seule ligne, formats absolus homogènes (le v25 mêlait
     « demain 08h30 » relatif et « dimanche 5 juillet 2026, 12:00 » absolu). #}
  <p style="font-size:10px;color:#8a8880;margin:0;">Prochain rapport · {{footer.next_morning or footer.next_report_at or 'demain 08:30'}} · Prochain hebdo · {{footer.next_weekly or 'dimanche prochain 12:00'}}</p>
  {# v27 (ME4) — indice de confiance du mail (sources actives + fraîcheur). #}
  {% if mail_confidence and mail_confidence.pct is not none %}
  <p style="font-size:9px;color:#8a8880;margin:8px 0 0 0;">Confiance du rapport · <strong style="color:{% if (mail_confidence.pct|num(0)) >= 70 %}#3B6D11{% elif (mail_confidence.pct|num(0)) >= 50 %}#BA7517{% else %}#A32D2D{% endif %};">{{mail_confidence.pct}}% ({{mail_confidence.grade}})</strong> · {{mail_confidence.sources}} sources{% if mail_confidence.onchain_as_of %} · on-chain au {{mail_confidence.onchain_as_of}}{% endif %}</p>
  {% endif %}
  {# v27 (AF5) — légende unique des codes couleur (cohérence de lecture). #}
  <p style="font-size:9px;color:#8a8880;margin:6px 0 0 0;">Légende · <span style="color:#3B6D11;">■</span> achat/haussier · <span style="color:#A32D2D;">■</span> vente/baissier · <span style="color:#BA7517;">■</span> prudence · 🔴 invalidation franchie</p>
  <p style="font-size:9px;color:#b5b3ab;margin:8px 0 0 0;">Crypto Analyst Pro · {{app_version or "v15"}}</p>
  <p style="font-size:9px;color:#8a8880;margin:8px 0 0 0;font-style:italic;">{{ disclaimer or "Analyse informative, pas un conseil en investissement. Fais tes propres recherches avant toute décision." }}</p>
</div>
