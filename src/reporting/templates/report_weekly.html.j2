{# Rapport hebdo V8 — bilan semaine + scénarios + LT, mail-safe.
   Refonte intégrale appliquant les 37 points du prompt utilisateur :
   - Header en <table> mail-safe (point 31 h1 25px)
   - Portfolio 4 KPI horizontaux : Valeur · vs BTC 7j · P&L semaine · Cash USDC
     (points 1+9+10) — drawdown supprimé, P&L semaine partout en remplacement
   - Scoring en table 4 col (point 11), win rate gris quand 0 (point 12)
   - Calibration toujours présente + message neutre si vide (point 3)
   - Coût des erreurs : mini-bannière 1 ligne si vide, structure dense sinon (point 15)
   - Top movers en 2-col 50% (point 16), format "WLD · +33.5%" (point 33)
   - Exit plan : tableau compact 2-col tickers/valeur (point 17)
   - Scénarios : titre split + badge proba + bannière action + repli (points 18-20)
   - Probabilités scénarios : note de bas (point 7)
   - Positionnement LT : vrai tableau compact (Option A point 21)
   - Bilan angles morts récurrents toujours présent + message neutre (point 4)
   - Sources actives bilan : 2 sous-listes structurées (point 27)
   - h1 25px, h2 17px (point 31), sous-titres uppercase 12px #1a1a18 (point 32)
   - Format prix unifié via fmt_price (point 34), % 1 décimale via fmt_pct (point 35)
   - Pastilles ² (point 6)
   - Footer heures Casablanca HH:MM (point 39), corrections cron (points 29-30) #}

{% set _cps = crypto_price_status or {} %}
{% set _mss = macro_source_status or {} %}

{# ── HEADER (table mail-safe, h1 25px) ── #}
<div style="border-bottom:0.5px solid #e5e4dc;padding-bottom:1rem;margin-bottom:1.5rem;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;">
    <tr>
      <td style="vertical-align:top;">
        <p style="font-size:12px;color:#5a5852;margin:0 0 4px 0;">{{header.time_casablanca or header.date}}{% if header.week_number %} · semaine {{header.week_number}}/{{header.year or 2026}}{% endif %}</p>
        <h1 style="margin:0;font-size:25px;font-weight:500;line-height:1.2;">Rapport hebdomadaire</h1>
        <p style="font-size:12px;color:#8a8880;margin:6px 0 0 0;">Bilan{% if header.period_covered %} {{header.period_covered}}{% else %} semaine passée{% endif %} · focus semaine à venir</p>
        {% if header.sources_week_label %}<p style="font-size:10px;color:#8a8880;margin:4px 0 0 0;">{{header.sources_week_label}}</p>{% endif %}
        {# v26 (W-A15) — run hors-cycle signalé honnêtement (comme le « fenêtre courte » du soir). #}
        {% if header.offcycle_note %}<p style="font-size:10px;color:#BA7517;margin:4px 0 0 0;">⏱ {{header.offcycle_note}}</p>{% endif %}
      </td>
      <td style="vertical-align:top;text-align:right;white-space:nowrap;padding-left:12px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">PTF</p>
        {# Bug 2 : si value_usd absent, masquer la zone valeur (pas de tiret orphelin). #}
        {% if portfolio_snapshot.value_usd %}
        <p style="font-size:18px;font-weight:500;margin:2px 0 0 0;">{{ portfolio_snapshot.value_usd|fmt_price }}</p>
        {% endif %}
        {% if (portfolio_snapshot.weekly_pnl_pct|default(none)) is not none %}<p style="font-size:10px;color:{% if (portfolio_snapshot.weekly_pnl_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};margin:0;">{{ portfolio_snapshot.weekly_pnl_pct|fmt_pct }} sem.</p>{% endif %}
        {# v23 — winrate 30j en tête (une fois, comme le matin/soir). #}
        {% set _wr_parts_w = (header.win_rate_total or '0/0').split('/') %}
        {% set _wr_total_w = (_wr_parts_w[1]|num(0)) if (_wr_parts_w|length > 1) else 0 %}
        {% set _wr_val_w = header.win_rate_30d|num(none) %}
        {# v28 (M-A15) — < 5 clôtures : « en calibration (2/2) », plus de %
           flatteur non calibré (aligné sur les headers matin/soir). #}
        <p style="font-size:10px;color:#8a8880;margin:8px 0 0 0;">Win rate 30j · <span style="font-weight:600;color:{% if _wr_total_w >= 5 and _wr_val_w is not none and _wr_val_w >= 50 %}#3B6D11{% elif _wr_total_w >= 5 and _wr_val_w is not none and _wr_val_w < 50 %}#A32D2D{% else %}#5a5852{% endif %};">{% if _wr_total_w < 1 or _wr_val_w is none %}— pas encore d'historique{% elif _wr_total_w < 5 %}en calibration ({{header.win_rate_total}}){% else %}{{ '%.0f'|format(_wr_val_w) }}%{% endif %}</span></p>
      </td>
    </tr>
  </table>
</div>

{# ── v28 (4.2) — BANDEAU MODE DÉGRADÉ : l'hebdo a été rédigé par le modèle de
   repli (profond indisponible malgré l'insistance différée). Signalé
   honnêtement plutôt que de laisser passer une analyse au rabais pour normale. #}
{% if _model_degraded %}
<div style="background:#FCEBEB;border:0.5px solid #E5B9B9;border-radius:8px;padding:8px 14px;margin-bottom:1rem;">
  <p style="margin:0;font-size:12px;color:#791F1F;line-height:1.5;"><span style="font-weight:700;">⚠ Analyse générée en mode dégradé</span> · {{ _model_degraded_note or "modèle profond indisponible — analyse rédigée par le modèle de repli." }}</p>
</div>
{% endif %}

{# ── v27 (ME1) — RÉGIME DE MARCHÉ en tête (le cadre de toute la semaine). ── #}
{% if market_regime and market_regime.available %}
{% set _rgw = market_regime.regime %}
{% set _rgwbg = '#EAF3DE' if _rgw == 'bull' else ('#FCEBEB' if _rgw == 'bear' else ('#FAEEDA' if _rgw == 'transition' else '#EEF2F7')) %}
{% set _rgwfg = '#27500A' if _rgw == 'bull' else ('#791F1F' if _rgw == 'bear' else ('#633806' if _rgw == 'transition' else '#0C447C')) %}
<div style="background:{{_rgwbg}};border-radius:8px;padding:8px 14px;margin-bottom:1rem;">
  {# v28 (M-A5/W-A6) — libellé « Régime BTC (technique) » : distinct du biais
     directionnel des scénarios (le 07/07 : « BAISSIER » au-dessus de scénarios
     85% non-baissiers semblait contradictoire — concepts différents). #}
  <p style="margin:0;font-size:12px;color:{{_rgwfg}};line-height:1.5;"><span style="font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Régime BTC (technique) : {{market_regime.label_fr}}</span>{% if market_regime.days_in_regime is not none %} <span style="color:#5a5852;">· depuis {{market_regime.days_in_regime}} j</span>{% endif %}{% if market_regime.reasons %} <span style="color:#5a5852;">· {{ market_regime.reasons|join(' · ') }}</span>{% endif %}{% if market_regime.changed and market_regime.previous_label_fr %} <span style="font-weight:700;">· ⚠️ {{market_regime.previous_label_fr}} → {{market_regime.label_fr}}</span>{% endif %}</p>
  {# v28 (W-A6) — une phrase déterministe explique la coexistence régime
     technique ↔ scénarios court terme quand ils semblent se contredire. #}
  {% if regime_reconciliation_note %}<p style="margin:4px 0 0 0;font-size:10px;color:#5a5852;line-height:1.5;">{{regime_reconciliation_note}}</p>{% endif %}
</div>
{% endif %}

{# ── v27 (ME2/ME3) — VERDICT des appels de la semaine passée (auto-évaluation). ── #}
{% if calls_review and calls_review.available and calls_review.summary_line %}
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:8px;padding:10px 14px;margin-bottom:1rem;">
  <p style="margin:0 0 3px 0;font-size:10px;color:#8a8880;text-transform:uppercase;letter-spacing:0.5px;font-weight:600;">Mes appels de la semaine passée · verdict</p>
  <p style="margin:0;font-size:12px;color:#33312e;line-height:1.55;">📏 {{calls_review.summary_line}}</p>
</div>
{% endif %}

{# ── BILAN SEMAINE (v16 : bulletpoints explicatifs + gras sur termes clés) ── #}
<h2 style="margin:0 0 0.75rem 0;font-size:17px;font-weight:500;">Bilan semaine{% if header.week_number %} {{header.week_number}}{% endif %} · ce qui s'est passé</h2>
<div style="background:#f5f4ee;border-radius:12px;padding:14px 16px;margin-bottom:1.5rem;">
  {# v25 — truthiness D'ABORD : un weekly_summary ABSENT (Undefined) passait le
     test « is iterable » → boîte VIDE au lieu du texte de repli. #}
  {% if weekly_summary and weekly_summary is iterable and weekly_summary is not string %}
  {% for b in weekly_summary %}
  <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;"><tr>
    <td style="width:16px;vertical-align:top;font-size:13px;line-height:1.6;color:#534AB7;">•</td>
    <td style="font-size:13px;line-height:1.6;color:#1a1a18;padding-bottom:{{ '6px' if not loop.last else '0' }};">{{ (b.text if b is mapping else b)|md }}</td>
  </tr></table>
  {% endfor %}
  {% else %}
  <p style="margin:0;font-size:13px;line-height:1.7;">{{ weekly_summary|md if weekly_summary else "Synthèse de la semaine en cours de préparation." }}</p>
  {% endif %}
</div>

{# ── v26 (W-B9) — DEPUIS LE HEBDO PRÉCÉDENT : diff déterministe WoW (valeur,
   santé, F&G, dollar). Absent la 1re semaine (pas de snapshot N-1). ── #}
{% if week_over_week and week_over_week.available and week_over_week.lines %}
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:8px;padding:10px 14px;margin:-0.75rem 0 1.5rem 0;">
  <p style="margin:0 0 4px 0;font-size:10px;color:#8a8880;text-transform:uppercase;letter-spacing:0.5px;font-weight:600;">Depuis le hebdo précédent{% if week_over_week.prev_date_label %} <span style="text-transform:none;letter-spacing:0;font-weight:400;">(du {{week_over_week.prev_date_label}})</span>{% endif %}</p>
  <p style="margin:0;font-size:12px;color:#33312e;line-height:1.6;">{{ week_over_week.lines|join(' · ') }}</p>
  {# v28 (W-A16) — lever la confusion des DEUX bases : « P&L semaine » = fenêtre
     7 j glissante ; ce bloc = variation depuis le dernier hebdo daté. #}
  <p style="margin:4px 0 0 0;font-size:9px;color:#a8a6a0;font-style:italic;">« P&L semaine » (en-tête) = 7 jours glissants ; ce bloc compare au dernier rapport hebdo.</p>
</div>
{% endif %}

{# ── PORTFOLIO · VUE D'ENSEMBLE (table 4 col 25%, P&L semaine remplace
   drawdown — points 9+10) ── #}
<h2 style="margin:1.5rem 0 0.75rem 0;font-size:17px;font-weight:500;">Portfolio · vue d'ensemble</h2>
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:12px;padding:1rem 1.25rem;margin-bottom:1rem;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;table-layout:fixed;">
    <tr>
      <td style="width:25%;vertical-align:top;padding-right:6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Valeur</p>
        <p style="font-size:15px;font-weight:500;margin:2px 0 0 0;color:#1a1a18;">{% if portfolio_snapshot.value_usd %}{{ portfolio_snapshot.value_usd|fmt_price }}{% else %}—{% endif %}</p>
      </td>
      <td style="width:25%;vertical-align:top;padding-right:6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">vs BTC 7j</p>
        <p style="font-size:15px;font-weight:500;margin:2px 0 0 0;color:{% if (portfolio_snapshot.vs_btc_7d_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{% if (portfolio_snapshot.vs_btc_7d_pct|default(none)) is not none %}{{ portfolio_snapshot.vs_btc_7d_pct|fmt_pct }}{% else %}—{% endif %}</p>
        {# v28 (W-A3) — écart négligeable (±0,05 pt) : « en ligne avec BTC »
           plutôt qu'un « outperform » déroutant sous un +0.0% affiché. #}
        {% set _vsb = portfolio_snapshot.vs_btc_7d_pct|num(0) %}
        {% if (portfolio_snapshot.vs_btc_7d_pct|default(none)) is not none %}<p style="font-size:10px;color:#8a8880;margin:0;">{{ 'en ligne avec BTC' if (_vsb < 0.05 and _vsb > -0.05) else ('outperform' if _vsb >= 0 else 'underperform') }}</p>{% endif %}
      </td>
      <td style="width:25%;vertical-align:top;padding-right:6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">P&amp;L semaine</p>
        <p style="font-size:15px;font-weight:500;margin:2px 0 0 0;color:{% if (portfolio_snapshot.weekly_pnl_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{% if (portfolio_snapshot.weekly_pnl_pct|default(none)) is not none %}{{ portfolio_snapshot.weekly_pnl_pct|fmt_pct }}{% else %}—{% endif %}</p>
        {% if (portfolio_snapshot.weekly_pnl_usd|default(none)) is not none %}<p style="font-size:10px;color:#5a5852;margin:0;">{% if (portfolio_snapshot.weekly_pnl_usd|num(0)) >= 0 %}+${{ '{:,.0f}'.format((portfolio_snapshot.weekly_pnl_usd)|num(0)) }}{% else %}−${{ '{:,.0f}'.format(((portfolio_snapshot.weekly_pnl_usd)|num(0))|abs) }}{% endif %}</p>{% endif %}
      </td>
      <td style="width:25%;vertical-align:top;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Cash USDC</p>
        {% set _ucp = portfolio_snapshot.usdc_pct|num(none) %}
        <p style="font-size:15px;font-weight:500;margin:2px 0 0 0;color:#1a1a18;">{% if _ucp is not none %}{{ _ucp|round|int }}%{% else %}—{% endif %}</p>
        {% if _ucp is not none and _ucp < 1 %}<p style="font-size:10px;color:#8a8880;margin:0;">100% investi</p>{% elif portfolio_snapshot.usdc_usd %}<p style="font-size:10px;color:#8a8880;margin:0;">{{ portfolio_snapshot.usdc_usd|fmt_price }}</p>{% endif %}
      </td>
    </tr>
  </table>

  {# ── B2 — PERF vs BENCHMARKS (PTF / BTC / ETH sur 7j) ── #}
  {% if (portfolio_snapshot.ptf_7d_pct|default(none)) is not none and (portfolio_snapshot.eth_7d_pct|default(none)) is not none %}
  <div style="margin:14px 0 0 0;font-size:12px;color:#5a5852;line-height:1.6;">
    <span style="font-weight:500;color:#1a1a18;">Perf 7j vs benchmarks :</span>
    PTF <span style="font-weight:600;color:{% if (portfolio_snapshot.ptf_7d_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{{ portfolio_snapshot.ptf_7d_pct|fmt_pct }}</span>
    {% if (portfolio_snapshot.btc_7d_pct|default(none)) is not none %} · BTC <span style="color:{% if (portfolio_snapshot.btc_7d_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{{ portfolio_snapshot.btc_7d_pct|fmt_pct }}</span>{% endif %}
    · ETH <span style="color:{% if (portfolio_snapshot.eth_7d_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{{ portfolio_snapshot.eth_7d_pct|fmt_pct }}</span>
    {% if (portfolio_snapshot.vs_eth_7d_pct|default(none)) is not none %}<span style="color:#8a8880;"> · PTF vs ETH {{ portfolio_snapshot.vs_eth_7d_pct|fmt_pct }}</span>{% endif %}
  </div>
  {% endif %}

  {# ── v23 — ÉVOLUTION PTF : vraie COURBE (aire + base 100 vs BTC) en image CID.
     Repli sur mini-barres HTML/CSS (Gmail-safe) si le PNG n'a pas été généré
     (matplotlib absent / historique < 3 points). ── #}
  {% set _vals = [] %}
  {% for _e in (ptf_evolution or []) %}{% if (_e.value is not none) and (_e.value is number) %}{% set _ = _vals.append(_e.value) %}{% endif %}{% endfor %}
  {% if charts and charts.get('ptf_evolution') %}
  <div style="margin:14px 0 0 0;">
    <img src="cid:chart_ptf_evolution" alt="Évolution du portefeuille" style="width:100%;max-width:660px;height:auto;display:block;border:0.5px solid #e5e4dc;border-radius:8px;">
    {% if (_vals|length) >= 2 %}<p style="font-size:10px;color:#8a8880;margin:3px 0 0 0;">{{ _vals[0]|fmt_price }} (il y a {{_vals|length - 1}} sem.) → {{ _vals[-1]|fmt_price }} (auj.)</p>{% endif %}
  </div>
  {% elif (_vals|length) >= 2 %}
  {% set _mn = _vals|min %}{% set _mx = _vals|max %}{% set _rng = (_mx - _mn) if (_mx - _mn) > 0 else 1 %}
  <div style="margin:14px 0 0 0;">
    <p style="font-size:10px;color:#8a8880;margin:0 0 4px 0;text-transform:uppercase;letter-spacing:0.5px;">Évolution PTF ({{_vals|length}} semaines)</p>
    <table role="presentation" cellpadding="0" cellspacing="2" border="0" style="border-collapse:separate;">
      <tr>
        {% for v in _vals %}
        {% set _hh = (6 + ((v - _mn) / _rng) * 26)|round(0)|int %}
        <td style="vertical-align:bottom;width:18px;">
          <div style="background:{% if loop.last and _vals[-1] >= _vals[0] %}#3B6D11{% elif loop.last %}#A32D2D{% else %}#cfcdc3{% endif %};height:{{_hh}}px;width:14px;border-radius:2px 2px 0 0;font-size:0;line-height:0;">&nbsp;</div>
        </td>
        {% endfor %}
      </tr>
    </table>
    <p style="font-size:10px;color:#8a8880;margin:2px 0 0 0;">{{ _vals[0]|fmt_price }} (il y a {{_vals|length - 1}} sem.) → {{ _vals[-1]|fmt_price }} (auj.)</p>
  </div>
  {% endif %}
  {# v15 (audit P0-8) — fenêtre du P&L semaine EXPLICITE : début → fin. #}
  {% if portfolio_snapshot.week_start_value and portfolio_snapshot.week_end_value %}
  <p style="font-size:10px;color:#8a8880;margin:10px 0 0 0;">Fenêtre du P&amp;L semaine : {{portfolio_snapshot.week_start_value|fmt_price}} (il y a 7 j) → {{portfolio_snapshot.week_end_value|fmt_price}} (aujourd'hui){% if header.period_covered %} · {{header.period_covered}}{% endif %}.</p>
  {% endif %}
  {# ── GESTION ACTIVE VS BTC HOLD : SUPPRIMÉ en v16 (Omar dispose déjà de cette
     comparaison ailleurs ; règle au passage le doublon « [fenêtre : 7 jours] »). ── #}

  {# ── v15 — SCORE QUALITÉ PTF (4 axes 0-10, formules Python transparentes) ── #}
  {% if ptf_quality_score %}
  {% set _q = ptf_quality_score %}
  <div style="background:#f5f4ee;border-radius:8px;padding:10px 12px;margin:14px 0 0 0;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;">
      <tr>
        <td style="vertical-align:middle;white-space:nowrap;padding-right:14px;">
          <span style="font-size:10px;color:#8a8880;text-transform:uppercase;letter-spacing:0.5px;">Santé du portefeuille</span><br>
          <span style="font-size:20px;font-weight:700;color:{% if (_q.score|num(0)) >= 6.5 %}#3B6D11{% elif (_q.score|num(0)) >= 4 %}#BA7517{% else %}#A32D2D{% endif %};">{{_q.score}}</span><span style="font-size:11px;color:#8a8880;">/10</span>
          {% if _q.delta_wow is not none %}<br><span style="font-size:10px;color:{% if (_q.delta_wow|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{{ '+' if (_q.delta_wow|num(0)) >= 0 else '' }}{{_q.delta_wow}} vs sem. dernière</span>{% endif %}
        </td>
        <td style="vertical-align:middle;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;">
            {% for ax in _q.axes %}
            {% set _aw = ((ax.score|num(0)) * 10)|round(0)|int %}
            <tr>
              <td style="font-size:10px;color:#5a5852;white-space:nowrap;padding:1px 8px 1px 0;width:108px;">{{ax.label}}</td>
              <td style="vertical-align:middle;padding:1px 8px 1px 0;">
                <div style="background:#e5e4dc;border-radius:3px;height:6px;width:100%;max-width:150px;"><div style="background:{% if _aw >= 65 %}#3B6D11{% elif _aw >= 40 %}#BA7517{% else %}#A32D2D{% endif %};border-radius:3px;height:6px;width:{{[_aw, 2]|max}}%;"></div></div>
              </td>
              <td style="font-size:10px;color:#8a8880;white-space:nowrap;padding:1px 0;width:118px;">{{ax.score}}/10 · {{ax.detail}}</td>
            </tr>
            {% endfor %}
          </table>
        </td>
      </tr>
    </table>
    {% if _q.improve %}<p style="font-size:11px;color:#1a1a18;margin:8px 0 0 0;"><span style="font-weight:600;">Pour l'améliorer :</span> {{_q.improve}}</p>{% endif %}
    {# v28 (3.B/W-A14) — jauge SUPPRIMÉE : le 3.2/10 + les 3 axes suffisent
       (une donnée = un seul affichage, template v25 strict). #}
    <p style="font-size:9px;color:#8a8880;margin:6px 0 0 0;font-style:italic;">Santé du portefeuille = santé structurelle (diversification, momentum vs BTC, solidité vs ATH), moyenne des 3 axes — même logique que la note Santé des mails matin/soir.</p>
  </div>
  {% endif %}
  {# v24 — bloc « Top mouvements de la semaine » (▲ Gagnants / ▼ Perdants) SUPPRIMÉ
     à la demande d'Omar. Les mouvements restent dispo dans la heatmap 7j + le
     contexte LLM (bilan semaine), mais ne sont plus affichés en section dédiée. #}

  {# v23.x — exposition sectorielle en CASES colorées (homogène avec la heatmap
     du matin) : 5 secteurs individuels + « Autres secteurs » = 6 cases. Chaque
     case affiche les variations marché 24h / 7j / 30j (une ligne chacune, lisible)
     et jusqu'à 5 cryptos du secteur (séparées par des virgules) + « +N » pour le
     reste. Fallback barres si absent. #}
  {% if sector_exposure_cells %}
  <p style="font-size:12px;color:#1a1a18;margin:16px 0 8px 0;text-transform:uppercase;letter-spacing:0.3px;font-weight:500;">Exposition sectorielle du portefeuille</p>
  {# v28 (3.B/W-A14) — donut SUPPRIMÉ : les cases ci-dessous portaient déjà les
     mêmes % avec EN PLUS les perfs 24h/7j/30j (template v25 strict). #}
  <table role="presentation" cellpadding="0" cellspacing="4" border="0" style="width:100%;border-collapse:separate;table-layout:fixed;">
    {% for row in sector_exposure_cells|batch(3) %}
    <tr>
      {% for s in row %}
      {% set _pp = s.ptf_pct|num(0) %}
      {% set _bg = '#E6F1FB' if _pp >= 40 else ('#EEF4FA' if _pp >= 20 else '#F4F7FB') %}
      <td style="background:{{_bg}};border-radius:6px;padding:10px 9px;width:33%;vertical-align:top;">
        <div style="font-size:11px;font-weight:700;color:#1a1a18;line-height:1.25;">{{s.sector}}</div>
        <div style="font-size:15px;font-weight:700;color:#0C447C;line-height:1.3;margin-bottom:3px;">{{ '%.1f'|format(_pp) }}% <span style="font-size:9px;font-weight:400;color:#8a8880;">du PTF</span></div>
        {% for _lbl, _k in [('24h','market_change_24h'),('7j','market_change_7d'),('30j','market_change_30d')] %}
          {% set _v = s[_k]|default(none) %}
          {% if _v is not none %}<div style="font-size:9.5px;line-height:1.45;color:#5a5852;"><span style="display:inline-block;width:24px;color:#8a8880;">{{_lbl}}</span><span style="color:{% if (_v|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};font-weight:600;">{{ '+' if (_v|num(0)) >= 0 else '−' }}{{ '%.1f'|format((_v|num(0))|abs) }}%</span></div>{% endif %}
        {% endfor %}
        {% if s.holdings %}<div style="font-size:9px;color:#5a5852;line-height:1.3;margin-top:3px;">{{ s.holdings[:5]|join(', ') }}{% if s.holdings|length > 5 %} +{{s.holdings|length - 5}}{% endif %}</div>{% endif %}
      </td>
      {% endfor %}
      {% if row|length < 3 %}{% for _ in range(3 - row|length) %}<td style="width:33%;"></td>{% endfor %}{% endif %}
    </tr>
    {% endfor %}
  </table>
  {% else %}
  {% set _sectors = (sector_exposure_computed.sectors if (sector_exposure_computed and sector_exposure_computed.available) else sector_exposure) %}
  {% if _sectors %}
  <p style="font-size:12px;color:#1a1a18;margin:16px 0 8px 0;text-transform:uppercase;letter-spacing:0.3px;font-weight:500;">Exposition sectorielle du portefeuille</p>
  {% for s in _sectors %}
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;{% if not loop.last %}border-bottom:0.5px solid #e5e4dc;{% endif %}">
    <tr>
      <td style="width:148px;padding:6px 0;font-size:12px;vertical-align:top;"><strong>{{s.sector}}</strong>{% if s.holdings %} <span style="color:#8a8880;font-size:10px;">({{ s.holdings[:3]|join(', ') }}{% if s.holdings|length > 3 %}…{% endif %})</span>{% endif %}</td>
      <td style="padding:6px 12px;vertical-align:middle;">
        <div style="height:6px;background:#f5f4ee;border-radius:3px;position:relative;">
          <div style="position:absolute;left:0;top:0;height:100%;width:{{ s.ptf_pct|num(0) }}%;background:{{s.color or '#534AB7'}};border-radius:3px;"></div>
        </div>
      </td>
      <td style="width:138px;padding:6px 0;font-size:11px;text-align:right;color:#5a5852;vertical-align:top;">{{s.ptf_pct}}% PTF{% if (s.market_change_24h|default(none)) is not none %} · {{ s.market_change_24h|fmt_pct }}/24h{% elif s.market_pct %} · {{s.market_pct}}% marché{% endif %}</td>
    </tr>
  </table>
  {% endfor %}
  {% endif %}
  {% endif %}

  {# ── CORRÉLATION ENTRE TES POSITIONS : SUPPRIMÉ en v16 — les actifs exemples
     sont désormais affichés directement à côté de chaque secteur ci-dessus,
     ce qui rend ce bloc redondant. On garde la « Lecture concentration ». ── #}

  {# v23.x — UN SEUL bloc « Lecture concentration » (Omar : fusion des 2 textes).
     Si une alerte de concentration est active (déterministe, chiffrée), elle EST
     la lecture (faits + action, zéro blabla) et le bloc prend un accent d'alerte ;
     sinon, la lecture qualitative de l'IA. Plus jamais deux blocs redondants. #}
  {% set _alerting = rebalance_alert and rebalance_alert.active %}
  {% set _conc = rebalance_alert.message if _alerting else (concentration_reading or position_correlation.concentration_reading) %}
  {% if _conc %}
  <div style="background:{{ '#FBF3E4' if _alerting else '#f5f4ee' }};{% if _alerting %}border:1px solid #E5C168;border-left:3px solid #BA7517;{% endif %}border-radius:8px;padding:10px 12px;margin:12px 0 0 0;font-size:12px;line-height:1.6;color:{{ '#5a4a28' if _alerting else '#1a1a18' }};">
    <p style="margin:0 0 4px 0;font-size:{{ '9px' if _alerting else '11px' }};text-transform:uppercase;{% if _alerting %}letter-spacing:1px;font-weight:700;color:#8A5A12;{% else %}letter-spacing:0.3px;font-weight:500;color:#1a1a18;{% endif %}">{% if _alerting %}⚖️ {% endif %}Lecture concentration</p>
    {{ _conc|md }}
  </div>
  {% endif %}
</div>

{# ── HEATMAP PORTFOLIO · 7J (v23.x — identique au matin mais sur 7 jours, placée
   sous l'exposition sectorielle). Tri par |perf 7j| décroissante, même code
   couleur, 4 lignes × 5 cases + « +N autres ». #}
{% if portfolio_heatmap_7d and portfolio_heatmap_7d.cells %}
<div style="margin-bottom:1.5rem;">
  <p style="font-size:11px;color:#5a5852;margin:16px 0 8px 0;text-transform:uppercase;letter-spacing:0.5px;font-weight:500;">Heatmap · performance 7j</p>
  {% set _hm_cells = portfolio_heatmap_7d.cells %}
  {% if portfolio_heatmap_7d.extra and portfolio_heatmap_7d.extra.count %}
  {% set _hm_cells = portfolio_heatmap_7d.cells + [{'symbol': '+' ~ portfolio_heatmap_7d.extra.count ~ ' autres', 'change_24h': portfolio_heatmap_7d.extra.avg_change_24h, 'ptf_pct': portfolio_heatmap_7d.extra.ptf_pct, 'is_extra': true}] %}
  {% endif %}
  <table role="presentation" cellpadding="0" cellspacing="3" border="0" style="width:100%;border-collapse:separate;table-layout:fixed;">
    {% for row in _hm_cells|batch(5) %}
    <tr>
      {% for cell in row %}
      {% set ch = cell.change_24h|num(none) %}
      {# v26 (W-A19) — seuils recalibrés pour une fenêtre 7 JOURS (±10/±3, au
         lieu des ±5/±2 du heatmap 24h du matin) : sinon presque toutes les
         cases ressortent « vert fort » et la nuance visuelle disparaît. #}
      {% set bg = '#e5e4dc' if ch is none else ('#C0DD97' if ch >= 10 else ('#EAF3DE' if ch >= 3 else ('#F4F8EC' if ch >= 0 else ('#F7C1C1' if ch <= -10 else ('#FCEBEB' if ch <= -3 else '#FDF1F1'))))) %}
      <td style="background:{{bg}};border-radius:3px;padding:6px 3px;text-align:center;width:20%;height:46px;vertical-align:middle;{% if cell.is_extra %}border:1px dashed #b5b3ab;{% endif %}">
        <div style="font-size:{% if cell.is_extra %}9px{% else %}11px{% endif %};font-weight:700;color:#1a1a18;line-height:1.25;">{{cell.symbol}}</div>
        <div style="font-size:10px;color:#1a1a18;line-height:1.25;">{% if ch is not none %}{{ '+' if ch >= 0 else '−' }}{{ '%.1f'|format(ch|abs) }}%{% else %}—{% endif %}</div>
        <div style="font-size:9px;color:#5a5852;line-height:1.25;">{% if (cell.ptf_pct|num(none)) is not none %}{{ '%.1f'|format(cell.ptf_pct|num(0)) }}% PTF{% if cell.is_extra %} <span style="font-size:8px;">moy.</span>{% endif %}{% endif %}</div>
      </td>
      {% endfor %}
      {% if row|length < 5 %}{% for _ in range(5 - row|length) %}<td style="width:20%;"></td>{% endfor %}{% endif %}
    </tr>
    {% endfor %}
  </table>
  {% if portfolio_heatmap_7d.extra and portfolio_heatmap_7d.extra.count %}
  <p style="font-size:10px;font-style:italic;color:#8a8880;margin:6px 0 0 0;">Chaque case : actif · perf 7j · poids PTF. « +{{portfolio_heatmap_7d.extra.count}} autres » = {{ '%.1f'|format(portfolio_heatmap_7d.extra.ptf_pct|num(0)) }}% du PTF (${{ '%.0f'|format(portfolio_heatmap_7d.extra.value_usd|num(0)) }}), perf 7j moyenne pondérée.</p>
  {% endif %}
  {# v28 (3.B/W-A4/W-A15) — barres perf 7j SUPPRIMÉES (mêmes chiffres que la
     heatmap ci-dessus, et le bar chart du 07/07 omettait BTC, 42% du PTF !) ;
     matrice de corrélation SUPPRIMÉE (mur de rouge illisible) et remplacée
     par UNE phrase calculée, directement actionnable. #}
  {% if correlation_summary_line %}
  <p style="font-size:11px;color:#5a5852;margin:10px 0 0 0;">⚖ {{correlation_summary_line}}</p>
  {% endif %}
</div>
{% endif %}

{# v23.x — FIL ROUGE MACRO déplacé SOUS « Semaine à venir · ce qui peut bouger »
   (demande d'Omar) : il commente désormais le calendrier qui le précède. #}

{# ── SCORING PRÉDICTIONS (table 4 col mail-safe, win rate gris si 0/0) ──
   Points 11 (table 4 col), 12 (gris quand 0), 13 (suppression phrase
   redondante), 14 (leçon 12px italique #1a1a18), 38 (ligne win rate
   secondaire claire). #}
<h2 style="margin:1.5rem 0 0.75rem 0;font-size:17px;font-weight:500;">Mes prédictions de la semaine · scoring</h2>
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:12px;padding:1rem 1.25rem;margin-bottom:1.5rem;">
  {% if predictions_scoring %}
  {% set _ps = predictions_scoring %}
  {% set _wr_total = (_ps.validated|num(0)) + (_ps.invalidated|num(0)) + (_ps.neutral|num(0)) %}
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;table-layout:fixed;">
    <tr>
      <td style="width:25%;vertical-align:top;padding:8px;background:#f5f4ee;border-radius:6px 0 0 6px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Recos émises</p>
        <p style="font-size:18px;font-weight:500;margin:2px 0 0 0;color:#1a1a18;">{{_ps.issued or 0}}</p>
      </td>
      <td style="width:25%;vertical-align:top;padding:8px;background:#f5f4ee;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Validées</p>
        <p style="font-size:18px;font-weight:500;margin:2px 0 0 0;color:{% if (_ps.validated|num(0)) > 0 %}#3B6D11{% else %}#5a5852{% endif %};">{{_ps.validated or 0}}</p>
      </td>
      <td style="width:25%;vertical-align:top;padding:8px;background:#f5f4ee;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Invalidées</p>
        <p style="font-size:18px;font-weight:500;margin:2px 0 0 0;color:{% if (_ps.invalidated|num(0)) > 0 %}#A32D2D{% else %}#5a5852{% endif %};">{{_ps.invalidated or 0}}</p>
      </td>
      <td style="width:25%;vertical-align:top;padding:8px;background:#f5f4ee;border-radius:0 6px 6px 0;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Win rate sem.</p>
        {# Point 12 : "—" gris si _wr_total < 5 (insuffisant pour calculer). #}
        <p style="font-size:18px;font-weight:500;margin:2px 0 0 0;color:{% if _wr_total >= 5 and (_ps.win_rate_pct|num(none)) is not none and (_ps.win_rate_pct|num(0)) >= 50 %}#3B6D11{% elif _wr_total >= 5 and (_ps.win_rate_pct|num(none)) is not none and (_ps.win_rate_pct|num(0)) < 50 %}#A32D2D{% else %}#5a5852{% endif %};">{% if _wr_total < 5 or (_ps.win_rate_pct|num(none)) is none %}—{% else %}{{_ps.win_rate_pct}}%{% endif %}</p>
      </td>
    </tr>
  </table>
  {# Point 38 : ligne secondaire claire "Win rate sem. · — · Win rate 30j · —". #}
  <p style="font-size:11px;color:#8a8880;margin:8px 0 0 0;">Win rate sem. · {% if _wr_total < 5 or (_ps.win_rate_pct|num(none)) is none %}—{% else %}{{_ps.win_rate_pct}}%{% endif %} · Win rate 30j · {% if (_ps.win_rate_30d|num(none)) is not none %}{{_ps.win_rate_30d}}%{% else %}—{% endif %}</p>
  {# v16 — jauge de calibration explicite dans le header (et plus seulement en
     légende) : « Recos clôturées : X/5 minimum pour calibration ». #}
  {% if _ps.winrate_gate_label %}
  <p style="font-size:11px;color:#BA7517;margin:4px 0 0 0;font-weight:500;">⚖ {{_ps.winrate_gate_label}}</p>
  {% endif %}

  {# v23.x — le DÉTAIL par-actif (entrée/Δ/jours/statut) a été FUSIONNÉ dans le
     tableau unique « Positions · 30j & long terme » plus bas (anti-doublon : il
     répétait aussi le suivi des mails matin/soir). Ici, on ne garde que le
     SCORING agrégé (win-rate, calibration, espérance, leçon). #}

  {# Point 14 : leçon de la semaine 12px #1a1a18 italique. #}
  {% if _ps.lesson %}
  <p style="font-size:12px;color:#1a1a18;margin:12px 0 0 0;font-style:italic;line-height:1.55;"><span style="font-weight:500;font-style:normal;">Leçon de la semaine ·</span> {{_ps.lesson}}</p>
  {% endif %}
  {# v15 (audit P3-2) — calibration FUSIONNÉE ici (sous-bloc compact) : plus de
     section dédiée qui répétait « pas encore d'historique ». #}
  {# v21 (W8) — si AUCUNE des 3 métriques (calibration / espérance / cibles) n'a
     encore de données, UNE seule note consolidée au lieu de répéter 3× la même
     phrase « disponible après 5 recos ». Détail complet dès qu'une métrique existe. #}
  {% set _calib_on = calibration and calibration.buckets %}
  {% set _exp_on = expectancy and expectancy.available %}
  {% set _tgt_on = target_calibration and target_calibration.available %}
  {% if not (_calib_on or _exp_on or _tgt_on) %}
  <div style="margin:12px 0 0 0;padding-top:10px;border-top:0.5px solid #f0efe8;">
    <p style="font-size:10px;color:#8a8880;margin:0 0 4px 0;text-transform:uppercase;letter-spacing:0.5px;">Calibration · espérance · cibles</p>
    <p style="font-size:11px;color:#8a8880;font-style:italic;margin:0;line-height:1.5;">Calibration de confiance, espérance mathématique et calibration des cibles de prix : disponibles dès 5 recos clôturées (avec niveaux et cibles). Aucune clôturée pour l'instant.</p>
  </div>
  {% else %}
  <div style="margin:12px 0 0 0;padding-top:10px;border-top:0.5px solid #f0efe8;">
    <p style="font-size:10px;color:#8a8880;margin:0 0 4px 0;text-transform:uppercase;letter-spacing:0.5px;">Calibration · confiance annoncée vs réalisée</p>
    {% if calibration and calibration.buckets %}
    {% for b in calibration.buckets %}
    <p style="margin:0 0 2px 0;font-size:11px;color:#5a5852;">Confiance {{b.range}} → réalisé <span style="font-weight:600;color:#1a1a18;">{{b.realized_pct}}%</span>{% if b.label %} <span style="color:{% if b.label == 'sur-confiance' %}#A32D2D{% elif b.label == 'sous-confiance' %}#0C447C{% else %}#3B6D11{% endif %};">({{b.label}})</span>{% endif %}</p>
    {% endfor %}
    {% if calibration.reading %}<p style="font-size:11px;color:#5a5852;margin:6px 0 0 0;line-height:1.5;">{{calibration.reading}}</p>{% endif %}
    {% else %}
    <p style="font-size:11px;color:#8a8880;font-style:italic;margin:0;">{{ (calibration and calibration.empty_reason) or "Disponible après 5 recos clôturées minimum." }}</p>
    {% endif %}
  </div>
  {# v18 (W-B12) — espérance mathématique. v28 (W-A12) : une métrique VIDE ne
     consomme plus une section entière — le 07/07, « disponible dès 5 recos »
     occupait 2 blocs séparés sous une calibration déjà affichée. #}
  {% if _exp_on %}
  <div style="margin:12px 0 0 0;padding-top:10px;border-top:0.5px solid #f0efe8;">
    <p style="font-size:10px;color:#8a8880;margin:0 0 4px 0;text-transform:uppercase;letter-spacing:0.5px;">Espérance mathématique · par reco</p>
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;"><tr>
      <td style="vertical-align:middle;white-space:nowrap;padding-right:14px;">
        <span style="font-size:20px;font-weight:700;color:{% if (expectancy.expectancy_pct|num(0)) > 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{{ '+' if (expectancy.expectancy_pct|num(0)) >= 0 else '' }}{{expectancy.expectancy_pct}}%</span>
        <span style="font-size:10px;color:#8a8880;"> / reco</span>
      </td>
      <td style="vertical-align:middle;font-size:11px;color:#5a5852;line-height:1.5;">{{expectancy.reading}}</td>
    </tr></table>
  </div>
  {% endif %}
  {% if _tgt_on %}
  <div style="margin:12px 0 0 0;padding-top:10px;border-top:0.5px solid #f0efe8;">
    <p style="font-size:10px;color:#8a8880;margin:0 0 4px 0;text-transform:uppercase;letter-spacing:0.5px;">Calibration des cibles de prix</p>
    <p style="margin:0;font-size:11px;color:#5a5852;line-height:1.5;"><span style="font-weight:600;color:{% if target_calibration.bias == 'calibrées' %}#3B6D11{% elif target_calibration.bias == 'légèrement optimistes' %}#BA7517{% else %}#A32D2D{% endif %};">{{target_calibration.hit_rate_pct}}% atteintes</span> · {{target_calibration.reading}}</p>
  </div>
  {% endif %}
  {% if not _exp_on or not _tgt_on %}
  <div style="margin:12px 0 0 0;padding-top:10px;border-top:0.5px solid #f0efe8;">
    <p style="font-size:11px;color:#8a8880;font-style:italic;margin:0;line-height:1.5;">{% if not _exp_on and not _tgt_on %}Espérance mathématique et calibration des cibles : disponibles dès 5 recos clôturées (avec niveaux et cibles).{% elif not _exp_on %}Espérance mathématique : disponible dès 5 recos clôturées avec niveaux.{% else %}Calibration des cibles : disponible dès 5 recos clôturées avec cible et prix de sortie.{% endif %}</p>
  </div>
  {% endif %}
  {% endif %}{# fin consolidation v21 (W8) #}
  {% else %}
  <p style="font-size:12px;color:#8a8880;font-style:italic;margin:0;">{{ predictions_empty_reason or "Première semaine, pas encore d'historique de prédictions à scorer." }}</p>
  {% endif %}
</div>
{# anchor-weekly-scoring-card-end #}

{# ── v27 (ES4/ES5) — CALIBRATION FINE (Brier) + AUTO-BACKTEST de la stratégie
   maison. Deux thermomètres honnêtes de la qualité du process. ── #}
{% if (brier_score and brier_score.available) or (strategy_backtest and strategy_backtest.available) %}
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:12px;padding:0.75rem 1.25rem;margin-bottom:1.5rem;">
  {% if brier_score and brier_score.available %}
  <p style="margin:0 0 4px 0;font-size:10px;color:#8a8880;text-transform:uppercase;letter-spacing:0.5px;">Calibration fine · score de Brier</p>
  <p style="margin:0 0 8px 0;font-size:12px;color:#33312e;line-height:1.55;"><span style="font-size:16px;font-weight:700;color:{% if (brier_score.brier|num(1)) <= 0.18 %}#3B6D11{% elif (brier_score.brier|num(1)) <= 0.25 %}#BA7517{% else %}#A32D2D{% endif %};">{{brier_score.brier}}</span> <span style="color:#8a8880;">({{brier_score.grade}}, n={{brier_score.n}})</span> — {{brier_score.reading}}</p>
  {% endif %}
  {% if strategy_backtest and strategy_backtest.available %}
  <p style="margin:{% if brier_score and brier_score.available %}8px{% else %}0{% endif %} 0 4px 0;font-size:10px;color:#8a8880;text-transform:uppercase;letter-spacing:0.5px;">Auto-backtest · « accumuler sous MM{{strategy_backtest.ma_period}} » (BTC)</p>
  <p style="margin:0;font-size:12px;color:#33312e;line-height:1.55;">{% for h, s in strategy_backtest.horizons.items() %}<strong>{{h}}j</strong> : {{s.hit_rate_pct}}% de hausse, retour médian {{ '%+.1f'|format(s.median_ret_pct|num(0)) }}% (n={{s.n}}){% if not loop.last %} · {% endif %}{% endfor %}</p>
  <p style="margin:4px 0 0 0;font-size:10px;color:#8a8880;font-style:italic;">{{strategy_backtest.note}}</p>
  {% endif %}
</div>
{% endif %}

{# ── POST-MORTEM DE LA SEMAINE (fusion v24) — les 3 blocs qui parlaient de la
   même chose (pertes↔recos + coût des erreurs + mon erreur) regroupés en UNE
   seule carte, sous-titres + couleurs sémantiques conservées, séparateurs légers.
   La calibration vit dans la carte scoring (fusion P3-2). ── #}
<h2 style="margin:1.5rem 0 0.75rem 0;font-size:17px;font-weight:500;">Post-mortem de la semaine · pertes, coûts &amp; erreur</h2>
<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-radius:12px;padding:1rem 1.25rem;margin-bottom:1.5rem;font-size:12px;line-height:1.6;color:#33312e;">
  {% if losses_vs_recos %}
  <div style="padding-bottom:10px;margin-bottom:10px;border-bottom:0.5px solid #efeee7;">
    <p style="margin:0 0 3px 0;font-weight:600;color:#791F1F;">Pertes de la semaine · lien avec mes recos</p>
    <div style="color:#501313;">{{losses_vs_recos|md}}</div>
  </div>
  {% endif %}
  <div{% if my_errors %} style="padding-bottom:10px;margin-bottom:10px;border-bottom:0.5px solid #efeee7;"{% endif %}>
    <p style="margin:0 0 3px 0;font-weight:600;color:#1a1a18;">Coût des erreurs · le regret de la semaine</p>
    {% if regret and regret.entries %}
    {% for it in regret.entries %}
    <div style="padding:4px 0;{% if not loop.last %}border-bottom:0.5px solid #e5e4dc;{% endif %}line-height:1.5;">
      <span style="font-weight:500;">{{it.asset}}</span> — {{it.description}}{% if it.cost_pct is not none %} <span style="color:#A32D2D;font-weight:500;">{{ it.cost_pct|fmt_pct }} {{it.cost_label or 'non capturés'}}</span>{% endif %}{% if it.cost_usd %} ≈ {{ it.cost_usd|fmt_price }}{% endif %}
    </div>
    {% endfor %}
    {% if regret.total_note %}<p style="color:#5a5852;margin:8px 0 0 0;line-height:1.5;"><span style="font-weight:500;">Regret total :</span> {{regret.total_note}}</p>{% endif %}
    {% else %}
    <p style="margin:0;color:#5a5852;">{{ (regret and regret.empty_reason) or "Pas encore de reco clôturée sur la fenêtre · mesure disponible dès la première clôture." }}</p>
    {% endif %}
  </div>
  {% if my_errors %}
  <div>
    <p style="margin:0 0 3px 0;font-weight:600;color:#633806;">Mon erreur de la semaine</p>
