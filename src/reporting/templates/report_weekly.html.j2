  {% endif %}
  {% for a in (weekly_action_plan or []) %}
  <div style="padding:8px 0;{% if not loop.last %}border-bottom:0.5px solid #f0efe9;{% endif %}">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;"><tr>
      <td style="vertical-align:top;width:26px;"><span style="display:inline-block;width:20px;height:20px;background:#534AB7;color:#fff;border-radius:50%;text-align:center;line-height:20px;font-size:11px;font-weight:700;">{{a.priority or loop.index}}</span></td>
      <td style="vertical-align:top;font-size:12px;line-height:1.5;"><span style="font-weight:600;color:#1a1a18;">{{a.action|md}}</span>{% if a.rationale %}<br><span style="color:#5a5852;font-size:11px;">{{a.rationale|md}}</span>{% endif %}</td>
    </tr></table>
