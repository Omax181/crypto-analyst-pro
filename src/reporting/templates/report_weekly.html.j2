{# ── SCÉNARIOS POUR LA SEMAINE (titre split + badge proba + bannière action
   + repli détails, points 18-20+7) ── #}
{% if scenarios %}
<h2 style="margin:1.5rem 0 0.75rem 0;font-size:17px;font-weight:500;">Scénarios pour la semaine</h2>
<div style="margin-bottom:1.5rem;">
  {% for s in scenarios %}
  {% set scen_bg = '#FCEBEB' if s.type == 'bearish' else ('#EAF3DE' if s.type == 'bullish' else '#FAEEDA') %}
  {% set scen_label = '#791F1F' if s.type == 'bearish' else ('#27500A' if s.type == 'bullish' else '#633806') %}
  {% set scen_text = '#501313' if s.type == 'bearish' else ('#173404' if s.type == 'bullish' else '#412402') %}
  {% set proba_bg = '#A32D2D' if s.type == 'bearish' else ('#3B6D11' if s.type == 'bullish' else '#BA7517') %}
  <div style="background:{{scen_bg}};border-radius:8px;padding:12px 14px;{% if not loop.last %}margin-bottom:10px;{% endif %}">
    {# Titre split : nom uppercase à gauche + badge proba à droite. #}
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;">
      <tr>
        <td style="vertical-align:middle;">
          <p style="margin:0;font-size:12px;color:{{scen_label}};text-transform:uppercase;letter-spacing:0.3px;font-weight:700;">{{s.label}}</p>
        </td>
        <td style="vertical-align:middle;text-align:right;white-space:nowrap;padding-left:8px;">
          <span style="display:inline-block;background:{{proba_bg}};color:#ffffff;font-size:11px;padding:3px 9px;border-radius:12px;font-weight:700;">{{s.probability_pct}}%</span>
        </td>
      </tr>
    </table>
    {# v24 — DÉCLENCHEURS : conditions concrètes qui activent le scénario, en liste
       claire (le « si X et Y et Z »), pour qu'Omar les garde en tête sur la semaine. #}
    {# v28 (W-A10) — GABARIT SERRÉ : le 07/07, 3 scénarios × ~9 puces (~27
       lignes) répétaient leurs propres déclencheurs. Caps DURS au rendu :
       2 déclencheurs + 2 points d'analyse max (l'action fait la 5e ligne). #}
    {% if s.triggers and s.triggers is iterable and s.triggers is not string %}
    <p style="margin:8px 0 2px 0;font-size:11px;color:{{scen_label}};font-weight:700;">🎯 Se déclenche si :</p>
    <ul style="margin:0;padding-left:18px;color:{{scen_text}};font-size:12px;line-height:1.5;">
      {% for t in s.triggers[:2] %}<li style="margin:1px 0;">{{ t|md }}</li>{% endfor %}
    </ul>
    {% endif %}
    {% if s.points and s.points is iterable and s.points is not string %}
    <ul style="margin:6px 0 0 0;padding-left:18px;color:{{scen_text}};font-size:12px;line-height:1.55;">
      {% for p in s.points[:2] %}<li style="margin:2px 0;">{{ p|md }}</li>{% endfor %}
    </ul>
    {% elif s.description %}<p style="margin:6px 0 0 0;font-size:12px;line-height:1.55;color:{{scen_text}};">{{s.description|md}}</p>{% endif %}
    {# Action en mini-bannière en bas de carte (point 19). #}
    {% if s.action %}
    <div style="background:{% if s.type == 'bearish' %}#F7C1C1{% elif s.type == 'bullish' %}#C0DD97{% else %}#F7D8AA{% endif %};border-radius:6px;padding:6px 10px;margin:8px 0 0 0;">
      <p style="margin:0;font-size:11px;color:{{scen_label}};font-weight:700;">ACTION · <span style="font-weight:500;">{{s.action|md}}</span></p>
    </div>
    {% endif %}
  </div>
  {% endfor %}
  {# Point 7 : disclaimer probabilités estimées par IA, pas modèle statistique. #}
  <p style="font-size:11px;color:#8a8880;font-style:italic;margin:8px 0 0 0;line-height:1.5;">Probabilités ancrées sur Polymarket, volatilité implicite (DVOL), régime macro, technique et calendrier — ajustées au jugement. Ordres de grandeur, pas une certitude.</p>
</div>
{% endif %}

