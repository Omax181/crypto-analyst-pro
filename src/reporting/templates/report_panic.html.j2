<!DOCTYPE html><html lang="fr"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0"></head>
<body style="margin:0;padding:16px;background:{{c.bg}};font-family:-apple-system,'Segoe UI',Roboto,Arial,sans-serif;color:{{c.text}};">
<div style="max-width:560px;margin:0 auto;background:{{c.card}};border-left:4px solid {{sev_color}};border-radius:6px;padding:16px 18px;">
  <div style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:{{sev_color}};font-weight:700;">🚨 Panic mode · alerte flash</div>
  <h1 style="margin:6px 0 8px;font-size:18px;color:{{c.accent}};">{{title}}</h1>
  <p style="margin:0;font-size:14px;line-height:1.55;">{{body}}</p>
  <div style="margin-top:14px;font-size:11px;color:{{c.muted}};">{{timestamp}} · {{disclaimer}}</div>
</div></body></html>
