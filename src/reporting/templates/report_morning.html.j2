  {% else %}
  {# v23.x (Omar) — icônes nettoyées : puce neutre • par défaut, ⚠️ jaune
     RÉSERVÉ aux points URGENTS/IMPORTANTS (icon ⚠). Plus de ✓/✗ (la croix
     d'invalidation jurait et prêtait à confusion). #}
  {% for b in executive_summary.bullets %}
  {% set _warn = b.icon in ['⚠', '⚠️'] %}
