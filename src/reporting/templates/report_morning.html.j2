  {# Groupe 1 — Crypto & sentiment #}
  {% set _g1_has = macro_context.btc_price or ((macro_context.fear_greed|default(none)) is not none) or ((macro_context.polymarket_fed_cut_pct|default(none)) is not none) or macro_context.dxy_ice or macro_context.dxy %}
  {% if _g1_has %}
