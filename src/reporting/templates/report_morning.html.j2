        <span style="font-size:22px;font-weight:700;color:{{health_score.level_color or '#1a1a18'}};">{{health_score.score}}</span><span style="font-size:12px;color:#8a8880;">/10</span>
        <span style="font-size:11px;font-weight:600;color:{{health_score.level_color or '#1a1a18'}};margin-left:4px;">{{health_score.level}}</span>
