        <p style="margin:2px 0 0 0;font-weight:500;font-size:15px;">{% if portfolio_snapshot.value_usd %}{{ portfolio_snapshot.value_usd|fmt_price }}{% else %}—{% endif %}</p>
      </td>
      <td style="width:20%;vertical-align:top;padding-right:6px;">
