  <div style="{% if health_score and (health_score.score is not none) %}padding-top:8px;border-top:0.5px solid #f0efe8;{% endif %}font-size:11px;color:#5a5852;line-height:1.55;">
    <p style="margin:0 0 4px 0;font-size:10px;font-weight:700;letter-spacing:0.5px;color:#8a8880;text-transform:uppercase;">Structure &amp; stress-test</p>
