        {% if portfolio_snapshot.overnight_pnl_usd is not none %}<p style="margin:0;font-size:10px;color:#5a5852;">{% if (portfolio_snapshot.overnight_pnl_usd|num(0)) >= 0 %}+${{ '{:,.0f}'.format((portfolio_snapshot.overnight_pnl_usd)|num(0)) }}{% else %}−${{ '{:,.0f}'.format(((portfolio_snapshot.overnight_pnl_usd)|num(0))|abs) }}{% endif %}</p>{% endif %}
      </td>
      <td style="width:20%;vertical-align:top;padding-right:6px;">
        <p style="margin:0;color:#8a8880;font-size:10px;">24h</p>
        <p style="margin:2px 0 0 0;font-weight:500;font-size:15px;color:{% if (portfolio_snapshot.change_24h_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{% if portfolio_snapshot.change_24h_pct is not none %}{{ portfolio_snapshot.change_24h_pct|fmt_pct }}{% else %}—{% endif %}</p>
      </td>
      <td style="width:20%;vertical-align:top;padding-right:6px;">
        <p style="margin:0;color:#8a8880;font-size:10px;">7j</p>
        <p style="margin:2px 0 0 0;font-weight:500;font-size:15px;color:{% if (portfolio_snapshot.change_7d_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{% if portfolio_snapshot.change_7d_pct is not none %}{{ portfolio_snapshot.change_7d_pct|fmt_pct }}{% else %}—{% endif %}</p>
      </td>
      <td style="width:20%;vertical-align:top;">
        <p style="margin:0;color:#8a8880;font-size:10px;">vs BTC 7j</p>
        <p style="margin:2px 0 0 0;font-weight:500;font-size:15px;color:{% if (portfolio_snapshot.vs_btc_7d_pct|num(0)) >= 0 %}#3B6D11{% else %}#A32D2D{% endif %};">{% if portfolio_snapshot.vs_btc_7d_pct is not none %}{{ portfolio_snapshot.vs_btc_7d_pct|fmt_pct }}{% else %}—{% endif %}</p>
      </td>
    </tr>
  </table>
  {% if portfolio_snapshot.usdc_usd %}<p style="margin:8px 0 0 0;font-size:11px;color:#5a5852;">💰 Cash disponible · <strong>{{ portfolio_snapshot.usdc_usd|fmt_price }}</strong>{% if portfolio_snapshot.usdc_pct is not none %} ({{portfolio_snapshot.usdc_pct}}% du PTF){% endif %} pour saisir des opportunités</p>{% endif %}
</div>

{# ── v27 (ME1) — RÉGIME DE MARCHÉ : le « temps qu'il fait » qui cadre tout.
   Bandeau en tête + alerte explicite si le régime a CHANGÉ. ── #}
