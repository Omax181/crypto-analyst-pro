<div style="background:#ffffff;border:0.5px solid #e5e4dc;border-left:3px solid {{ (health_score.level_color if health_score else none) or '#BA7517' }};border-radius:8px;padding:10px 14px;margin-bottom:1.5rem;">
  {% if health_score and (health_score.score is not none) %}
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;">
    <tr>
      <td style="vertical-align:middle;white-space:nowrap;padding-right:14px;">
