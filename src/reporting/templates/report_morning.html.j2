{# Rapport matin V6 — fidèle au mockup, couleurs hex (compat mail).
   Sections fixes ; contenu adaptatif piloté par le payload. #}

{# ── MACRO FLÈCHE 24h (v14 point 16) — verte hausse / rouge baisse / grise stable.
   Seuil adaptatif : un mouvement < 0,5% de la valeur de l'item est jugé stable
   (gris). delta = variation absolue (même unité que value). Pour une variation
   déjà en %, passer value=100 et delta=variation%. Rend "" si delta/valeur
   manquant (aucune flèche parasite). #}
{% macro arrow24(value, delta) -%}
{%- set v = value|num(0) -%}
{%- set d = delta|num(none) -%}
{%- if d is not none and v and v != 0 -%}
  {%- set pct = (d if d >= 0 else -d) / (v if v >= 0 else -v) * 100 -%}
  {%- if pct < 0.15 -%}<span style="color:#8a8880;font-size:12px;"> ▬</span>
  {%- elif d > 0 -%}<span style="color:#3B6D11;font-size:12px;"> ▲</span>
  {%- else -%}<span style="color:#A32D2D;font-size:12px;"> ▼</span>
  {%- endif -%}
{%- endif -%}
{%- endmacro %}

{# v18 (M-A16) — Δ24h CHIFFRÉ en pourcentage (la tuile BTC n'avait qu'une flèche
   sans nombre, contrairement aux autres tuiles). Affiche « +1.2% » / « −0.6% »
   coloré, ou rien si le delta n'est pas exploitable. #}
{% macro pct24(change_pct) -%}
{%- set c = change_pct|num(none) -%}
{%- if c is not none -%}
  {%- if (c if c >= 0 else -c) < 0.05 -%}<span style="color:#8a8880;font-size:10px;"> 0.0%</span>
  {%- elif c > 0 -%}<span style="color:#3B6D11;font-size:10px;"> +{{ '%.1f'|format(c) }}%</span>
  {%- else -%}<span style="color:#A32D2D;font-size:10px;"> −{{ '%.1f'|format(-c) }}%</span>
  {%- endif -%}
{%- endif -%}
{%- endmacro %}

{# v18 (M-B10) — ENCADRÉ D'ANALYSE STANDARDISÉ. C'est le bloc qu'Omar lit le plus :
   il doit être visuellement identique partout (même fond, même barre d'accent à
   gauche, même petit label en capitales). `label` = intitulé court (ex. « LECTURE
   MACRO »), `body` = prose, `accent` = couleur de la barre (défaut bleu ardoise). #}
{% macro analysis_callout(label, body, accent) -%}
{%- set _ac = accent or '#4A5568' -%}
<div style="background:#f7f6f1;border-left:3px solid {{_ac}};border-radius:6px;padding:10px 14px;margin:10px 0 0 0;">
  {%- if label %}<p style="margin:0 0 4px 0;font-size:9px;letter-spacing:1px;font-weight:700;color:{{_ac}};text-transform:uppercase;">{{label}}</p>{% endif %}
  <p style="margin:0;font-size:13px;line-height:1.65;color:#33312e;">{{ body|md }}</p>
</div>
{%- endmacro %}

{# ── HEADER ── #}
<div style="border-bottom:0.5px solid #e5e4dc;padding-bottom:1rem;margin-bottom:1.5rem;">
  {# Header en table pour rendu mail-safe (flex non supporté sur Gmail/Outlook
     → le bloc droit retombe en vertical au lieu de s'aligner à droite).
     Win rate (H1) :
       - 0 reco clôturée  → gris "—" + "pas encore d'historique"
       - 1≤n<5            → gris, valeur calculable mais peu fiable
       - n≥5 et win≥50%   → vert
       - n≥5 et win<50%   → rouge
  #}
  {% set _wr_parts = (header.win_rate_total or '0/0').split('/') %}
  {% set _wr_total = (_wr_parts[1]|num(0)) if (_wr_parts|length > 1) else 0 %}
  {% set _wr_val = header.win_rate_30d|num(none) %}
  {% if _wr_total >= 5 and _wr_val is not none and _wr_val >= 50 %}
    {% set _wr_color = '#3B6D11' %}
  {% elif _wr_total >= 5 and _wr_val is not none and _wr_val < 50 %}
    {% set _wr_color = '#A32D2D' %}
  {% else %}
    {% set _wr_color = '#5a5852' %}
  {% endif %}
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;">
    <tr>
      <td style="vertical-align:top;">
        <p style="font-size:12px;color:#5a5852;margin:0 0 4px 0;">{{header.time_casablanca or header.date}}</p>
        <h1 style="margin:0;font-size:25px;font-weight:500;line-height:1.2;">Veille crypto · matin</h1>
        <p style="font-size:12px;color:#8a8880;margin:6px 0 0 0;">{{header.active_sources_count or 0}}{% if header.total_sources_count %} / {{header.total_sources_count}}{% endif %} sources{% if header.firm_theses_count is defined %} · {{header.firm_theses_count or 0}} nouvelle{{'s' if (header.firm_theses_count or 0) > 1 else ''}} reco{% if header.active_recos_count is defined %} · {{header.active_recos_count or 0}} en suivi{% endif %}{% elif thesis_of_the_day %} · {{thesis_of_the_day|length}} thèse{{'s' if thesis_of_the_day|length > 1 else ''}} analysée{{'s' if thesis_of_the_day|length > 1 else ''}}{% endif %} · {{ header.subtitle_context or 'synthèse de la nuit' }}</p>
      </td>
      <td style="vertical-align:top;text-align:right;white-space:nowrap;padding-left:12px;">
        <p style="font-size:10px;color:#8a8880;margin:0;">Win rate 30j</p>
        {# v28 (M-A15) — < 5 clôtures : plus de « 100% » géant sur 2/2 (chiffre
           flatteur non calibré). Mention discrète « en calibration (2/2) ». #}
        {% if _wr_total >= 5 %}
        <p style="font-size:18px;font-weight:500;margin:2px 0 0 0;color:{{_wr_color}};">{% if _wr_val is not none %}{{ '%.0f'|format(_wr_val) }}%{% else %}—{% endif %}</p>
        <p style="font-size:9px;color:#8a8880;margin:0;">{{header.win_rate_total}}</p>
        {% elif _wr_total >= 1 %}
        <p style="font-size:12px;font-weight:500;margin:4px 0 0 0;color:#8a8880;">en calibration ({{header.win_rate_calibration or header.win_rate_total}})</p>
        <p style="font-size:9px;color:#8a8880;margin:0;">affiché dès 5 recos clôturées</p>
        {% else %}
        <p style="font-size:18px;font-weight:500;margin:2px 0 0 0;color:#5a5852;">—</p>
        <p style="font-size:9px;color:#8a8880;margin:0;">pas encore d'historique</p>
        {% endif %}
      </td>
    </tr>
  </table>
</div>

{# ── PORTFOLIO (5 métriques · table mail-safe) ── #}
